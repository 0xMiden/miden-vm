#! Loads a 128-bit little-endian chunk from memory as a canonical field value.
#! Input:  [ptr, ...]
#! Output: [FIELD_DIGEST, ...]
#! Memory layout: ptr[0..4] = chunk limbs; high field limbs are zero.
pub proc load_128_mem
    padw movup.4 mem_loadw_le
    # => [CHUNK_U32[4], ...]
