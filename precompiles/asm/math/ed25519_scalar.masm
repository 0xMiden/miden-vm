#! Evaluates two field expression digests and returns whether their canonical values match.
#! Input:  [LHS_DIGEST, RHS_DIGEST, ...]
#! Output: [is_equal, ...]
#!
#! This does not trap when the two values differ. Each digest is evaluated independently, and each
#! advised canonical value is bound by logging an equality assertion against the expression that
#! produced it. The returned bit is derived in MASM by comparing the two canonical field values.
pub proc is_eq
    # Evaluate/bind LHS first. `eval` preserves the lower stack, so RHS remains beneath LHS_VALUE.
    exec.eval
    # => [LHS_LO, LHS_HI, RHS_DIGEST, ...]

    movupw.2
    # => [RHS_DIGEST, LHS_LO, LHS_HI, ...]
    exec.eval
    # => [RHS_LO, RHS_HI, LHS_LO, LHS_HI, ...]

    # Compare the two field values one word at a time. `eqw` preserves both input words under
    # the returned bit, so each comparison must explicitly drop its operands before `and`.
    movupw.2
    # => [LHS_LO, RHS_LO, RHS_HI, LHS_HI, ...]
    eqw
    # => [lo_equal, LHS_LO, RHS_LO, RHS_HI, LHS_HI, ...]
    movdn.8 dropw dropw
    # => [lo_equal, RHS_HI, LHS_HI, ...]

    movdn.8
    # => [RHS_HI, LHS_HI, lo_equal, ...]
    eqw
    # => [hi_equal, RHS_HI, LHS_HI, lo_equal, ...]
    movdn.8 dropw dropw
    # => [hi_equal, lo_equal, ...]
    and
    # => [is_equal, ...]
end

