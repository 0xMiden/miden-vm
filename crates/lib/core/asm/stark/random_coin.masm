#! Random coin procedures for the STARK verifier.
#!
#! The `eidos_*` procedures implement the Eidos challenger. Unprefixed sampling and observe
#! helpers are recursive-verifier entry points over that state machine.
#!
#! Eidos challenger memory layout:
#!   random_coin_cv_ptr          - 4-felt chaining value
#!   random_coin_output_word_ptr - 4-felt output cache
#!   random_coin_block_ptr       - 8-felt absorb block
#!   random_coin_buffer_len_ptr  - position in the absorb block, 0..8
#!   random_coin_counter_ptr     - 0 = absorbing; otherwise next counter-mode block index
#!   random_coin_output_len_ptr  - felts left in the output cache, 0..4

use miden::core::stark::constants
use miden::core::stark::utils

# Eidos transcript-local root labels. These helper procs are available for typed
# transcript events even when the main recursive verifier uses the generic stream.
const MAIN_TRACE_ROOT_LABEL = 1
const AUX_TRACE_ROOT_LABEL = 2
const QUOTIENT_ROOT_LABEL = 3

# Eidos::transcript_init_cv(EIDOS_STARK_TRANSCRIPT_INIT_V1), where
# EIDOS_STARK_TRANSCRIPT_INIT_V1 = (2 << 8) | 1.
const EIDOS_TRANSCRIPT_INIT_CV_0 = 13584872457373224727
const EIDOS_TRANSCRIPT_INIT_CV_1 = 12762410475881036111
const EIDOS_TRANSCRIPT_INIT_CV_2 = 15838618209357359763
const EIDOS_TRANSCRIPT_INIT_CV_3 = 15449209033948119817

# Eidos challenger
# =============================================================================================

#! Enter absorbing mode after an Eidos absorb.
#!
#! Input: [...]
#! Output: [...]
pub proc eidos_enter_absorbing
    push.0 exec.constants::random_coin_counter_ptr mem_store
    push.0 exec.constants::random_coin_output_len_ptr mem_store
end

#! Clear the generic Eidos absorb buffer.
#!
#! Input: [...]
#! Output: [...]
pub proc eidos_clear_buffer
    padw exec.constants::random_coin_block_ptr mem_storew_le
    exec.constants::random_coin_block_ptr add.4 mem_storew_le dropw
    push.0 exec.constants::random_coin_buffer_len_ptr mem_store
end

#! Compress the block stored at `random_coin_block_ptr` into the Eidos chaining value.
#!
#! Input: [...]
#! Output: [...]
pub proc eidos_compress_block
    padw exec.constants::random_coin_cv_ptr mem_loadw_le
    padw exec.constants::random_coin_block_ptr add.4 mem_loadw_le
    padw exec.constants::random_coin_block_ptr mem_loadw_le
    bcompress
    swapw.2
    exec.constants::random_coin_cv_ptr mem_storew_le dropw
    dropw dropw
end

#! Absorb a fully specified 8-felt Eidos block.
#!
#! Input: [block_lo, block_hi, ...]
#! Output: [...]
pub proc eidos_absorb_block
    padw exec.constants::random_coin_cv_ptr mem_loadw_le
    swapw.2
    swapw
    bcompress
    swapw.2
    exec.constants::random_coin_cv_ptr mem_storew_le dropw
    dropw dropw
    exec.eidos_clear_buffer
    exec.eidos_enter_absorbing
end

#! Observe one felt through the generic Eidos streaming interface.
#!
#! Input: [value, ...]
#! Output: [...]
pub proc eidos_observe_felt
    exec.eidos_enter_absorbing

    exec.constants::random_coin_buffer_len_ptr mem_load
    dup push.8 u32lt assert.err="eidos_observe_felt: buffer_len exceeds block width"
    swap
    dup.1
    exec.constants::random_coin_block_ptr add mem_store
    add.1
    dup exec.constants::random_coin_buffer_len_ptr mem_store
    push.8 eq
    if.true
        exec.eidos_compress_block
        exec.eidos_clear_buffer
    end
end

#! Observe one word through the generic Eidos streaming interface.
#!
#! The fast path expects word-aligned transcript state (`buffer_len` 0 or 4), which is the shape
#! used by the recursive verifier except for proof-of-work witnesses.
#!
#! Input: [word, ...]
#! Output: [...]
pub proc eidos_observe_word
    exec.eidos_enter_absorbing

    exec.constants::random_coin_buffer_len_ptr mem_load
    dup push.0 eq
    if.true
        drop
        exec.constants::random_coin_block_ptr mem_storew_le dropw
        padw exec.constants::random_coin_block_ptr add.4 mem_storew_le dropw
        push.4 exec.constants::random_coin_buffer_len_ptr mem_store
    else
        push.4 assert_eq.err="eidos_observe_word: expected buffer_len 0 or 4"
        exec.constants::random_coin_block_ptr add.4 mem_storew_le dropw
        exec.eidos_compress_block
        exec.eidos_clear_buffer
    end
end

#! Observe the top two stack words as one Eidos block without changing the stack.
#!
#! Intended for `adv_pipe` loops that must keep both piped words available.
pub proc eidos_observe_piped_words
    dupw
    exec.eidos_observe_word
    swapw
    dupw
    exec.eidos_observe_word
    swapw
end

#! Absorb one word as `[word, 0, 0, 0, 0]`.
#!
#! Input: [word, ...]
#! Output: [...]
pub proc eidos_absorb_word
    padw
    swapw
    exec.eidos_absorb_block
end

#! Absorb the main trace commitment root.
#!
#! Input: [root, ...]
#! Output: [...]
pub proc eidos_absorb_main_trace_root
    push.0.0.0.MAIN_TRACE_ROOT_LABEL
    swapw
    exec.eidos_absorb_block
end

#! Absorb the auxiliary trace commitment root.
#!
#! Input: [root, ...]
#! Output: [...]
pub proc eidos_absorb_aux_trace_root
    push.0.0.0.AUX_TRACE_ROOT_LABEL
    swapw
    exec.eidos_absorb_block
end

#! Absorb the quotient commitment root.
#!
#! Input: [root, ...]
#! Output: [...]
pub proc eidos_absorb_quotient_root
    push.0.0.0.QUOTIENT_ROOT_LABEL
    swapw
    exec.eidos_absorb_block
end

#! Initialize the Eidos challenger from a transcript-init CV and relation digest.
#!
#! Input: [relation_digest, transcript_init_cv, ...]
#! Output: [...]
pub proc eidos_init_challenger
    swapw
    exec.constants::random_coin_cv_ptr mem_storew_le dropw

    exec.eidos_clear_buffer
    padw exec.constants::random_coin_output_word_ptr mem_storew_le dropw
    push.0 exec.constants::random_coin_output_len_ptr mem_store

    exec.eidos_absorb_word
end

#! Refill the 4-felt Eidos output word.
#!
#! Input: [...]
#! Output: [...]
pub proc eidos_refill_output_word
    exec.constants::random_coin_counter_ptr mem_load
    dup push.0 eq
    if.true
        drop
        exec.constants::random_coin_buffer_len_ptr mem_load
        dup push.8 u32lt assert.err="eidos_refill_output_word: buffer_len exceeds block width"
        exec.constants::random_coin_cv_ptr add.3 mem_load
        swap add.1 add
        exec.constants::random_coin_cv_ptr add.3 mem_store
        exec.eidos_compress_block
        exec.eidos_clear_buffer
        push.1 exec.constants::random_coin_counter_ptr mem_store
    else
        dup add.1 exec.constants::random_coin_counter_ptr mem_store
        push.0.0.0
        movup.3
        exec.constants::random_coin_block_ptr mem_storew_le
        drop push.0
        exec.constants::random_coin_block_ptr add.4 mem_storew_le dropw
        exec.constants::random_coin_cv_ptr add.3 mem_load
        push.9 add
        exec.constants::random_coin_cv_ptr add.3 mem_store
        exec.eidos_compress_block
        exec.eidos_clear_buffer
    end

    padw exec.constants::random_coin_cv_ptr mem_loadw_le
    exec.constants::random_coin_output_word_ptr mem_storew_le dropw
    push.4 exec.constants::random_coin_output_len_ptr mem_store
end

#! Sample one base field element from the Eidos transcript.
#!
#! Input: [...]
#! Output: [x, ...]
pub proc eidos_sample_felt
    exec.constants::random_coin_output_len_ptr mem_load
    dup push.0 eq
    if.true
        drop
        exec.eidos_refill_output_word
        push.4
    end

    dup push.4 u32lte assert.err="eidos_sample_felt: output_len exceeds word width"
    sub.1
    dup exec.constants::random_coin_output_len_ptr mem_store

    push.3 swap sub
    exec.constants::random_coin_output_word_ptr add mem_load
end

#! Sample one quadratic extension element from the Eidos transcript.
#!
#! Input: [...]
#! Output: [x0, x1, ...]
pub proc eidos_sample_ext
    exec.eidos_sample_felt
    exec.eidos_sample_felt
    swap
end

#! Sample bits from the Eidos transcript.
#!
#! Input: [bits, ...]
#! Output: [value, ...]
pub proc eidos_sample_bits
    dup
    pow2
    u32assert u32overflowing_sub.1 assertz
    exec.eidos_sample_felt
    u32split
    swap
    drop
    u32and
    swap
    drop
end

#! Return the next full Eidos output word.
#!
#! Input: [...]
#! Output: [word, ...]
pub proc eidos_squeeze_word
    exec.constants::random_coin_output_len_ptr mem_load
    push.0 assert_eq
    exec.eidos_refill_output_word
    padw exec.constants::random_coin_output_word_ptr mem_loadw_le
    push.0 exec.constants::random_coin_output_len_ptr mem_store
end

#! Sample a single base field element from the transcript.
#!
#! Input: [...]
#! Output: [x, ...]
pub proc sample_felt
    exec.eidos_sample_felt
end

#! Sample a quadratic extension field element from the transcript.
#!
#! Input: [...]
#! Output: [x0, x1, ...]
pub proc sample_ext
    exec.eidos_sample_ext
end

#! Sample a number of bits from the transcript.
#!
#! Input: [bits, ...]
#! Output: [value, ...]
pub proc sample_bits
    exec.eidos_sample_bits
end

#! Observe a single felt through the transcript stream.
#!
#! Input: [value, ...]
#! Output: [...]
pub proc observe_felt
    exec.eidos_observe_felt
end

#! Initializes the Eidos Fiat-Shamir transcript, then derives trace domain parameters.
#!
#! The instance-specific wrapper stores the relation digest in memory before calling the generic
#! verifier.
#!
#! Currently assumes a blowup factor equal to 8.
#!
#! Precondition: num_queries, query_pow_bits, deep_pow_bits, folding_pow_bits, relation digest,
#! and trace-height metadata must already be stored in memory before calling this procedure.
#!
#! Input: [...]
#! Output: [...]
pub proc init_seed
    # Initialize the zero word.
    padw
    exec.constants::zero_word_ptr mem_storew_le
    dropw
    #=> [...]

    # ---- Relation digest + PCS params ----

    push.EIDOS_TRANSCRIPT_INIT_CV_3.EIDOS_TRANSCRIPT_INIT_CV_2.EIDOS_TRANSCRIPT_INIT_CV_1.EIDOS_TRANSCRIPT_INIT_CV_0
    padw exec.constants::relation_digest_ptr mem_loadw_le
    exec.eidos_init_challenger

    # Absorb PCS parameters as one full Eidos block:
    # [nq, query_pow_bits, deep_pow_bits, folding_pow_bits,
    #  log_blowup, log_final_degree, fold_arity, 0].
    exec.constants::get_folding_pow_bits
    exec.constants::get_deep_pow_bits
    exec.constants::get_query_pow_bits
    exec.constants::get_number_queries

    push.0
    exec.constants::get_fri_fold_arity
    exec.constants::get_log_final_degree
    exec.constants::get_blowup_factor_log
    swapw
    exec.eidos_absorb_block
    #=> [...]

    # ---- Derive trace domain parameters ----
    #
    # Reload log(trace_length) from memory (it was saved earlier) and derive
    # trace_length, LDE domain size, LDE generator, and trace generator.

    exec.constants::get_trace_length_log
    #=> [log(trace_length), ...]

    ## Compute trace_length = 2^log(trace_length)
    dup
    pow2
    u32test assert.err="trace length overflows u32"
    #=> [trace_length, log(trace_length), ...]

    ## Save the trace length to memory
    dup exec.constants::set_trace_length
    #=> [trace_length, log(trace_length), ...]

    ## Compute log size of LDE domain
    swap
    exec.constants::get_blowup_factor_log
    add
    #=> [log(lde_size), trace_length, ...]

    ## Compute size of LDE domain
    dup
    pow2
    #=> [lde_size, log(lde_size), trace_length, ...]

    # Compute lde_domain generator
    dup.1
    exec.utils::compute_lde_generator
    movdn.2
    #=> [lde_size, log(lde_size), lde_g, trace_length, ...]

    # Store the LDE coset shift used by the lifted domains. It depends on LDE size and is used
    # by quotient recomposition and DEEP query points.
    dup.1
    exec.utils::compute_lde_shift
    dup exec.constants::set_domain_offset
    inv exec.constants::set_domain_offset_inv
    #=> [lde_size, log(lde_size), lde_g, trace_length, ...]

    push.0
    movdn.3
    #=> [lde_size, log(lde_size), lde_g, 0, trace_length, ...]

    # Save `[0, lde_g, log(lde_size), lde_size]`
    exec.constants::set_lde_domain_info_word
    #=> [lde_size, log(lde_size), lde_g, 0, trace_length, ...]

    # clean stack
    drop drop
    #=> [lde_g, 0, trace_length, ...]

    # Compute trace generator `trace_g` = `lde_g^blowup_factor`
    repeat.3
        dup mul
    end
    #=> [trace_g, 0, trace_length, ...]

    # Save `trace_g` to memory
    exec.constants::set_trace_domain_generator
    #=> [0, trace_length, ...]

    # Clean up the stack.
    drop drop
end

#! Observe the main-trace commitment after statement shape binding.
#!
#! Input: [c0, c1, c2, c3, ...]
#! Output: [...]
pub proc reseed_main_after_shape
    exec.eidos_observe_felt
    exec.eidos_observe_felt
    exec.eidos_observe_felt
    exec.eidos_observe_felt
end

#! Observe a commitment word and stage the per-round PoW witness.
#!
#! Input: [felt, w0, w1, w2, w3, ...]
#! Output: [...]
pub proc reseed_with_felt
    exec.constants::tmp3 mem_store
    exec.eidos_observe_word
end

#! Observe one commitment word.
#!
#! Input: [w0, w1, w2, w3, ...]
#! Output: [...]
pub proc reseed_direct
    exec.eidos_observe_word
end

#! Verify per-round FRI folding proof-of-work and sample one extension field element.
#!
#! The folding PoW bit count is read from memory (set by load_security_params).
#! When folding_pow_bits=0 the check is trivially satisfied (mask=0).
#!
#! Equivalent to: `get_folding_pow_bits sample_bits assertz; sample_ext`
#!
#! Must be called immediately after `reseed_with_felt`; the witness is staged in `tmp3`.
#!
#! Input: [...]
#! Output: [a0, a1, ...]
pub proc sample_folding_pow_and_ext
    exec.constants::get_folding_pow_bits
    dup push.0 neq
    if.true
        exec.constants::tmp3 mem_load
        exec.eidos_observe_felt
        exec.eidos_sample_bits
        assertz.err="per-round FRI folding grinding check failed"
    else
        drop
        exec.constants::tmp3 mem_load
        assertz.err="FRI folding proof-of-work nonce must be zero when grinding factor is zero"
    end

    exec.eidos_sample_ext
end

# COEFFICIENT GENERATION
# =============================================================================================

#! Draw a list of random extension field elements related to the auxiliary segment of the execution
#! trace and store them.
#!
#! More specifically, we draw two challenges, alpha and beta. This means that our multi-set hash function
#! has the form `h(m) = alpha + \sum_{i=0}^{|m| - 1} m_i * beta^i` for a message `m`.
#!
#! As these random challenges have already been used non-deterministically in prior computations, we
#! also check that the generated challenges match the non-deterministically provided one.
#!
#! Input: [...]
#! Output: [...]
pub proc generate_aux_randomness

    exec.sample_ext
    exec.sample_ext
    # => [beta0, beta1, alpha0, alpha1, ...]

    exec.constants::aux_rand_elem_ptr mem_storew_le
    # => [beta0, beta1, alpha0, alpha1, ...]

    # Pad with zeros, load with mem_loadw_le overwriting the padding so that we can compare
    padw
    # => [0, 0, 0, 0, beta0, beta1, alpha0, alpha1, ...]
    exec.constants::aux_rand_nd_ptr mem_loadw_le
    # => [nd_beta0, nd_beta1, nd_alpha0, nd_alpha1, beta0, beta1, alpha0, alpha1, ...]

    # Assert sampled values match the non-deterministically provided ones.
    # Comparison order: beta0, beta1, alpha0, alpha1 (memory offset 0, 1, 2, 3).
    movup.4 assert_eq.err="aux randomness mismatch at element 0 (beta0)"
    movup.3 assert_eq.err="aux randomness mismatch at element 1 (beta1)"
    movup.2 assert_eq.err="aux randomness mismatch at element 2 (alpha0)"
    assert_eq.err="aux randomness mismatch at element 3 (alpha1)"
    #=> [...]
end

#! Draw constraint composition random coefficient and save it at `compos_coef_ptr`.
#!
#! Input: [...]
#! Output: [...]
pub proc generate_constraint_composition_coefficients
    # Sample alpha (constraint folding challenge).
    exec.sample_ext
    push.0.0
    movup.3
    movup.3
    exec.constants::composition_coef_ptr
    mem_storew_le dropw

    # Sample beta for proof-order Horner folding, then write Word 5:
    # [multi_air_beta_0, multi_air_beta_1, reserved, reserved].
    exec.sample_ext
    # => [beta_0, beta_1, ...]
    push.0.0
    # => [0, 0, beta_0, beta_1, ...]
    movup.3 movup.3
    # => [beta_0, beta_1, 0, 0, ...]
    exec.constants::auxiliary_ace_inputs_ptr add.20
    mem_storew_le dropw
end

#! Draw deep composition polynomial random coefficient and save it at `deep_rand_coef_ptr`.
#!
#! As this random challenge has already been used non-deterministically in prior computations, we
#! also check that the generated challenge matches the non-deterministically provided one.
#!
#! Input: [...]
#! Output: [...]
pub proc generate_deep_composition_random_coefficients
    # Sample challenge_columns (deep alpha) for batching columns.
    exec.sample_ext
    padw
    exec.constants::deep_rand_alpha_nd_ptr mem_loadw_le
    # => [alpha0_nd, alpha1_nd, 0, 0, alpha0, alpha1, ...]

    dup.4 assert_eq
    dup.4 assert_eq
    exec.constants::deep_rand_coef_ptr
    mem_storew_le
    dropw

    # Sample challenge_points (deep beta) for batching evaluation points.
    # p3-miden's DEEP formula weights the gz term by beta:
    #   Q(X) = [f(z)-f(X)]/(z-X) + beta * [f(gz)-f(X)]/(gz-X)
    exec.sample_ext
    # => [beta0, beta1, ...]

    # Store [beta0, beta1, alpha0, alpha1] at deep_rand_coef_ptr.
    # (alpha was already stored at positions 2,3 by the mem_storew_le above)
    exec.constants::deep_rand_coef_ptr mem_store
    exec.constants::deep_rand_coef_ptr add.1 mem_store
    #=> [...]
end


# OOD POINT GENERATION
# =============================================================================================

#! Generate the OOD challenge point `z = (z0, z1)` and compute `z^N` where N is
#! the trace length. The resulting word `[(z_0, z_1)^N, z0, z1]` is stored in the
#! global memory address `exec.z_ptr` reserved for it.
#!
#! Input: [X, ...]
#! Output: [...]
#! Note: The top word on the stack is consumed by this procedure.
pub proc generate_z_zN
    # Sample z and load log trace length N
    exec.sample_ext
    exec.constants::get_trace_length_log
    # => [log(trace_len), z_0, z_1, ...]

    dup.2 dup.2
    # => [z_0, z_1, log(trace_len), z_0, z_1, ...]

    # Compute z^N using the fact that z^N = z^(2^log(N))
    # Loop starts with `i=log(trace_len)`
    push.1
    while.true
        dup.1 dup.1 ext2mul
        # => [(z_0, z_1)^n, i, z_0, z_1, ...]

        dup.2 sub.1 swap.3 push.1 neq
        # => [b, (z_0, z_1)^n, i-1, z_0, z_1, ...]
    end

    movup.2 drop
    # => [(z_0, z_1)^n, z_0, z_1, ...]

    # Store z and z^N
    exec.constants::z_ptr mem_storew_le
    dropw
end


# INDEX GENERATION
# =============================================================================================

#! Generate a list of `num_queries` number of random indices in the range
#! [0, lde_size) and store it in memory starting from `query_ptr`.
#! The list is stored as `(index, depth, index, 0)` where `index` is the sampled domain-order
#! index and `depth` is `log(lde_domain_size)`, which is needed when computing the DEEP queries.
#!
#! Input: [...]
#! Output: [...]
pub proc generate_list_indices
    exec.constants::get_number_queries
    exec.constants::get_fri_queries_address
    #=> [query_ptr, num_queries, ...]

    exec.constants::get_lde_domain_depth
    swap movup.2 swap
    #=> [query_ptr, num_queries, depth, ...]

    dup.1 push.0 neq
    while.true
        dup.2 exec.eidos_sample_bits
        #=> [index, query_ptr, num_queries, depth, ...]

        movdn.3
        #=> [query_ptr, num_queries, depth, index, ...]

        push.0
        dup.4
        dup.4
        dup.6
        #=> [index, depth, index, 0, query_ptr, num_queries, depth, index, ...]

        dup.4 mem_storew_le dropw
        #=> [query_ptr, num_queries, depth, index, ...]

        add.4
        movup.3 drop
        #=> [query_ptr + 4, num_queries, depth, ...]

        swap sub.1 swap
        #=> [query_ptr + 4, num_queries - 1, depth, ...]

        dup.1 push.0 neq
    end

    drop drop drop
end


# PROOF-OF-WORK CHECK
# =============================================================================================

#! Verify a proof-of-work witness given pow_bits on the stack.
#!
#! When pow_bits != 0, reads the nonce from advice, observes it, and checks that the next
#! sampled bits are zero.
#! When pow_bits == 0, consumes the witness (must be zero) without affecting the transcript.
#!
#! Used by check_query_pow (query phase) and check_deep_pow (DEEP phase).
#! FRI folding PoW uses a separate path (sample_folding_pow_and_ext) because the
#! witness is bundled with the commitment reseed.
#!
#! Input: [pow_bits, ...]
#! Output: [...]
proc check_pow
    dup
    push.0 neq
    if.true
        adv_push
        exec.eidos_observe_felt
        exec.eidos_sample_bits
        assertz.err="proof-of-work check failed"
    else
        # Consume witness to keep advice layout, but do not affect transcript.
        adv_push
        assertz.err="proof-of-work nonce must be zero when grinding factor is zero"
        drop
    end
end

#! Check the DEEP proof-of-work.
#!
#! Called before sampling DEEP composition polynomial challenges.
#!
#! Input: [...]
#! Output: [...]
pub proc check_deep_pow
    exec.constants::get_deep_pow_bits
    exec.check_pow
end

#! Check the query proof-of-work.
#!
#! Called after loading the FRI remainder, before sampling query indices.
#!
#! Input: [...]
#! Output: [...]
pub proc check_query_pow
    exec.constants::get_query_pow_bits
    exec.check_pow
end
