use miden::core::stark::constants

#! Processes the public inputs.
#!
#! This generic procedure dispatches to the relation-specific public-input handler via `dynexec`.
#! The relation handler owns its public-input schema and Fiat-Shamir observation schedule.
#!
#! Inputs:  [...]
#! Outputs: [...]
#!
#! Invocation: exec
pub proc process_public_inputs
    exec.constants::get_procedure_digest_process_public_inputs_ptr dynexec
end

#! Computes and stores the start address of the ACE public-input region.
#!
#! The public-input region stores `num_fixed_len_pi` base-field public values as extension-field
#! slots, i.e. two base-field memory cells per public value. It is placed immediately before the
#! aux-randomness word in ACE READ.
#!
#! This helper only computes the ACE READ public-input pointer. Relation-specific code owns any
#! additional statement inputs that are not read by the ACE circuit.
#!
#! Inputs:  [num_fixed_len_pi, ...]
#! Outputs: [...]
#!
#! Invocation: exec
pub proc compute_and_store_public_inputs_address
    exec.constants::aux_rand_elem_ptr
    # => [aux_rand_ptr, num_fixed_len_pi, ...]
    swap mul.2 sub
    # => [public_inputs_ptr, ...]

    exec.constants::public_inputs_address_ptr mem_store
end

#! Loads 8 base-field elements from memory, stores them as 8 extension-field elements, and leaves
#! the base elements in the rate slots for a direct full-rate absorption.
#!
#! Input:  [R1, R2, C, dst, src, ...]
#! Output: [R1', R2', C, dst + 16, src + 8, ...]
#!
#! Invocation: exec
pub proc load_base_store_extension_double_word_from_mem
    dup.13 mem_loadw_le
    exec.constants::tmp1 mem_storew_le
    movup.13 add.4 movdn.13

    swapw
    exec.constants::zeroize_stack_word
    # => [0, 0, 0, 0, a3, a2, a1, a0, C, dst, src, ...]
    movdn.7
    movdn.5
    movdn.3
    swap
    # => [a3, 0, a2, 0, a1, 0, a0, 0, C, dst, src, ...]

    dup.12
    mem_storew_le

    dup.13 mem_loadw_le
    exec.constants::tmp2 mem_storew_le
    movup.13 add.4 movdn.13
    swapw
    # => [a3, 0, a2, 0, a7, a6, a5, a4, C, dst, src, ...]

    dup.12 add.4
    mem_storew_le

    exec.constants::zeroize_stack_word
    movdn.7
    movdn.5
    movdn.3
    swap
    # => [a7, 0, a6, 0, a5, 0, a4, 0, C, dst, src, ...]

    dup.12
    add.8
    mem_storew_le
    exec.constants::tmp2 mem_loadw_le
    swapw

    dup.12
    add.16 swap.13
    add.12
    mem_storew_le
    exec.constants::tmp1 mem_loadw_le
    # => [a3, a2, a1, a0, a7, a6, a5, a4, C, dst + 16, src + 8, ...]
end
