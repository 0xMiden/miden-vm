use miden::precompiles::hashes::keccak256
use miden::precompiles::curves::secp256k1
use miden::precompiles::fields::k1_base
use miden::precompiles::fields::k1_scalar
use miden::core::crypto::hashes::poseidon2
use miden::core::word

# ENCODING CONVENTIONS
# ================================================================================================
#
# - Native secp256k1 values are stored as little-endian numeric u32 limbs, one limb per Felt.
# - The public-key commitment is `Poseidon2::hash_elements(QX[8] || QY[8])` over the native
#   coordinate limbs in advice/memory order.
# - MSG is a word whose four felts are split into eight little-endian u32 limbs before Keccak256.

# PROCEDURES
# ================================================================================================

#! Verifies a secp256k1 ECDSA witness using the `miden-crypto::ecdsa_k256_keccak` message,
#! public-key commitment, and signature-scalar conventions, encoded in the native limb ABI below.
#! Acceptance intentionally differs from the Rust verifier: high-s witnesses are accepted.
#!
#! Inputs:
#!   Operand stack: [PK_COMM, MSG, ...]
#!   Advice stack:  [QX[8] | QY[8] | SIG_R[8] | SIG_S[8] | ...]
#! Outputs:
#!   Operand stack: [...]
#!   Advice stack:  [...]
#!
#! Where:
#! - `PK_COMM`: Poseidon2 hash commitment of `QX[8] || QY[8]`, where coordinates are native
#!   little-endian numeric u32 limbs, one limb per Felt.
#! - `MSG`: single word / 4 felts representing the 32-byte message to verify.
#! - `QX[8]`, `QY[8]`: native public-key coordinates as little-endian u32 limbs.
#! - `SIG_R[8]`, `SIG_S[8]`: native signature scalars as little-endian u32 limbs.
#!
#! Local memory layout (element addresses):
#!   - loc[0 ..16] : native public key, QX[8] || QY[8].
#!   - loc[16..24] : Keccak256 message/digest scratch buffer.
#!
#! No result word is pushed. The procedure traps on malformed native limbs, invalid/off-curve public
#! keys, invalid signature scalars, or failed signature verification.
#!
#! Low-s is intentionally not enforced: this procedure proves that some untrusted advice satisfies
#! the ECDSA equation, and `(r, s)` and `(r, n - s)` are equivalent witnesses. An adaptation that
#! verifies a committed or canonical Ethereum signature must bind the exact signature encoding inside
#! the VM and enforce low-s on that bound value.
#!
#! Advice is untrusted. This procedure binds QX/QY to `PK_COMM`, and validates the public key,
#! reduced Keccak prehash, and signature scalars through precompile-backed deferred evaluation.
@locals(24)
pub proc verify
    # Load QX || QY from advice into the verifier public-key buffer while absorbing the same
    # two chunks into the Poseidon2 `hash_elements` state. Since there are exactly 16 elements,
    # the `hash_elements` capacity word is zero and no partial-block padding is required.
    # `adv_pipe` exposes each just-written chunk in the rate slots in the same order that
    # `mem_stream` would read it back from memory.
    locaddr.0 padw padw padw
    # => [R0=0w, R1=0w, C=0w, write_ptr=loc[0], PK_COMM, MSG, ...]
    adv_pipe
    # => [QX_RATE[8], C=0w, write_ptr=loc[8], PK_COMM, MSG, ...]
    hperm
    # => [R0, R1, C, write_ptr=loc[8], PK_COMM, MSG, ...]
    adv_pipe
    # => [QY_RATE[8], C, write_ptr=loc[16], PK_COMM, MSG, ...]
    hperm
    # => [R0, R1, C, write_ptr=loc[16], PK_COMM, MSG, ...]
    # Assert Poseidon2::hash_elements(QX[8] || QY[8]) == PK_COMM.
    exec.poseidon2::squeeze_digest
    # => [PK_HASH, write_ptr=loc[16], PK_COMM, MSG, ...]
    movup.4 movdn.8
    # => [PK_HASH, PK_COMM, write_ptr=loc[16], MSG, ...]
    assert_eqw.err="invalid public key commitment"
    # => [write_ptr=loc[16], MSG, ...]

    movdn.4
    # => [MSG, digest_ptr=loc[16], ...]

    # Stage MSG[32] in loc[16..24], hash it in-place via the memory-oriented Keccak precompile,
    # then convert the digest bytes into the native little-endian scalar limbs used as ECDSA z.
    exec.store_word_u32s_le
    # => [digest_ptr, ...]  (MSG_U32[8] written to loc[16..24])

    dup dup push.32 swap
    # => [in_ptr=loc[16], len_bytes=32, out_ptr=loc[16], digest_ptr=loc[16], ...]
    exec.keccak256::hash_1_chunk_mem
    # => [digest_ptr=loc[16], ...]  (DIGEST_U32[8] written to loc[16..24])

    dup sub.16 swap
    # => [read_ptr=loc[16], pubkey_ptr=loc[0], ...]
    repeat.8
        dup mem_load
        exec.reverse_u32_bytes
        swap add.1
    end
    # => [read_ptr=loc[24], PREHASH_U32[8], pubkey_ptr, ...]
    drop
    # => [PREHASH_U32[8], pubkey_ptr, ...] where PREHASH[0] = byte_reverse(KeccakDigest[7])

    exec.prepare_verify_inputs
    # => [U1, Q, U2, SIG_R, ...]

    # Untrusted, prover-supplied algorithm selector (1 = GLV, 0 = Straus): which path computes
    # `u1*G + u2*Q` is a pure performance choice, not a soundness one, since each path's own
    # certificate independently fails a wrong witness rather than forging one.
    adv_push
    # => [algo, U1, Q, U2, SIG_R, ...]
    dup dup dup mul assert_eq
    # => [algo, U1, Q, U2, SIG_R, ...]  (booleanity checked, one copy of algo survives)
    if.true
        locaddr.0
        # => [pubkey_ptr, U1, Q, U2, SIG_R, ...]
        movdn.12
        # => [U1, Q, U2, pubkey_ptr, SIG_R, ...]
        exec.verify_point_glv
        # => [VERIFY_POINT, SIG_R, ...]
    else
        exec.verify_point_straus
        # => [VERIFY_POINT, SIG_R, ...]
    end
    exec.assert_x_eq_scalar_k1
    # => [...]
end

# INTERNAL PROCEDURES — GLV
# ================================================================================================
#
# `verify_point_glv` computes `R = u1*G + u2*Q` via the secp256k1 GLV endomorphism instead of the
# naive 2-base MSM: each scalar splits into a signed short pair over the endomorphism basis
# (`u = ka + lambda*kb`), turning the 2-base ~256-bit MSM into a 4-base ~128-bit one (`k1a*G +
# k1b*phi(G) + k2a*Q + k2b*phi(Q)`), which the joint addition-chain strategy lays with roughly half
# the doublings. The split is untrusted advice, certified in-circuit two ways: `phi(P) = (beta*x_P
# mod p, y_P)` is proven on-curve when the deferred prover evaluates it (sound because `phi(P) =
# lambda*P` for any curve point whenever `beta^3 = 1 mod p` and `lambda^3 = 1 mod n` -- a fixed
# program constant, not attacker-influenced), and each split's recompose relation is checked
# directly against `u1`/`u2` via k1 scalar-field arithmetic below. A negative half routes its sign
# through the *base* (`sign ? -P : P`) rather than the scalar, so the four MSM scalars stay
# non-negative ~128-bit magnitudes -- what actually caps the ladder near 128 doublings.
#
# T0-2 note: this does not yet special-case a degenerate GLV split (duplicate canonical base
# across the four terms, e.g. Q colliding with G/phi(G), or a zero-magnitude half) -- the same class
# of liveness gap the audit tracks for the non-GLV path. Left for a follow-up; astronomically
# unlikely for a randomly chosen public key.

#! secp256k1 GLV base-field constant `beta` (`beta^3 = 1 mod p`), as a k1_base VALUE digest.
proc push_beta_digest
    push.0x7ae96a2b
    push.0x657c0710
    push.0x6e64479e
    push.0xac3434e9
    push.0x9cf04975
    push.0x12f58995
    push.0xc1396c28
    push.0x719501ee
    exec.k1_base::load
end

#! secp256k1 GLV scalar `lambda` (`lambda^3 = 1 mod n`), as a k1_scalar VALUE digest.
proc push_lambda_digest
    push.0x5363ad4c
    push.0xc05c30e0
    push.0xa5261c02
    push.0x8812645a
    push.0x122e22ea
    push.0x20816678
    push.0xdf02967c
    push.0x1b23bd72
    exec.k1_scalar::load
end

#! The secp256k1 generator's x-coordinate, as a k1_base VALUE digest.
proc push_gx_digest
    push.0x79be667e
    push.0xf9dcbbac
    push.0x55a06295
    push.0xce870b07
    push.0x029bfcdb
    push.0x2dce28d9
    push.0x59f2815b
    push.0x16f81798
    exec.k1_base::load
end

#! The secp256k1 generator's y-coordinate, as a k1_base VALUE digest.
proc push_gy_digest
    push.0x483ada77
    push.0x26a3c465
    push.0x5da4fbfc
    push.0x0e1108a8
    push.0xfd17b448
    push.0xa6855419
    push.0x9c47d08f
    push.0xfb10d4b8
    exec.k1_base::load
end

#! Builds `phi(P) = (beta*x_P mod p, y_P)` from `P`'s raw base-field coordinate digests -- the
#! secp256k1 GLV endomorphism image. On-curve membership (and hence `phi(P) = lambda*P`) is
#! certified when this digest is later evaluated, because `P` is on-curve and `beta^3 = 1 mod p`
#! keeps the curve equation satisfied.
#!
#! Input:  [bx, by, ...]
#! Output: [PHI_DIGEST, ...]
proc phi_point
    exec.push_beta_digest
    # => [BETA, bx, by, ...]
    swapw
    # => [bx, BETA, by, ...]
    exec.k1_base::mul
    # => [PHI_X, by, ...]
    exec.secp256k1::load_digest_pair
    # => [PHI_DIGEST, ...]
end

#! Pulls one signed GLV magnitude from advice: an 8-limb canonical k1 scalar magnitude, then a
#! sign felt (`1` = negative).
#!
#! Advice: [MAG_LO[4] | MAG_HI[4] | SIGN | ...]
#! Output: [sign, MAG_DIGEST, ...]
proc pull_signed_scalar
    exec.load_scalar_k1_from_advice
    # => [MAG_DIGEST, ...]
    adv_push
    # => [sign, MAG_DIGEST, ...]
    dup dup dup mul assert_eq
    # => [sign, MAG_DIGEST, ...]  (booleanity checked; one copy of sign survives)
end

#! Returns `sign ? neg(base) : base` -- routes a GLV half's sign through the base, so the MSM
#! ladder's scalar stays a non-negative magnitude.
#!
#! Input:  [sign, base, ...]
#! Output: [signed_base, ...]
proc signed_base
    if.true
        exec.secp256k1::neg
        # => [NEG_BASE, ...]
    else
        # => [base, ...]
    end
end

#! Returns `sign ? (0 - mag) : mag` -- the k1 scalar this signed half contributes to a mod-n
#! recompose sum.
#!
#! Input:  [sign, mag, ...]
#! Output: [hat, ...]
proc signed_hat
    if.true
        exec.k1_scalar::push_zero_digest
        # => [ZERO, mag, ...]
        exec.k1_scalar::sub
        # => [HAT, ...]
    else
        # => [mag, ...]
    end
end

#! Certifies `u == hat_a + lambda*hat_b (mod n)`, tying a term's two GLV halves back to the
#! original scalar. Traps immediately on mismatch (an incorrect GLV witness fails verification,
#! it can never forge one).
#!
#! Input:  [lambda, hat_b, hat_a, u, ...]
#! Output: [...]
proc assert_recompose
    exec.k1_scalar::mul
    # => [PROD, hat_a, u, ...]
    exec.k1_scalar::add
    # => [SUM, u, ...]
    exec.k1_scalar::is_eq
    # => [is_equal, ...]
    assert.err="GLV recompose check failed"
end

#! Computes `R = u1*G + u2*Q` via the secp256k1 GLV endomorphism (see the module note above).
#!
#! Each inlined half below follows the same shape: pull one signed magnitude from advice, load its
#! base digest from a fixed local slot, write the MSM pair `(signed_base, mag)` to the pair buffer,
#! and reduce to `hat = sign ? (0 - mag) : mag` for the term's recompose check.
#!
#! Advice: four [`pull_signed_scalar`] draws, in order: u1's `a` half, u1's `b` half, u2's `a`
#! half, u2's `b` half.
#! Input:  [U1, Q, U2, pubkey_ptr, ...]
#! Output: [VERIFY_POINT, ...]
@locals(56)
proc verify_point_glv
    # => [U1, Q, U2, pubkey_ptr, ...]

    # -- Gather phase: Q's raw coordinates (for phi(Q)), phi(Q), phi(G), G -- stash G/phi(G)/
    #    phi(Q)/Q/U1/U2 to locals so the process phase below can address them by fixed offset.
    movup.12
    # => [pubkey_ptr, U1, Q, U2, ...]
    dup
    # => [pubkey_ptr, pubkey_ptr, U1, Q, U2, ...]
    exec.k1_base::load_mem
    # => [BX, pubkey_ptr, U1, Q, U2, ...]
    locaddr.12 mem_storew_le dropw
    # => [pubkey_ptr, U1, Q, U2, ...]
    add.8
    # => [pubkey_ptr+8, U1, Q, U2, ...]
    exec.k1_base::load_mem
    # => [BY, U1, Q, U2, ...]
    locaddr.16 mem_storew_le dropw
    # => [U1, Q, U2, ...]

    swapw
    # => [Q, U1, U2, ...]
    padw locaddr.12 mem_loadw_le
    # => [BX, Q, U1, U2, ...]
    padw locaddr.16 mem_loadw_le
    # => [BY, BX, Q, U1, U2, ...]
    swapw
    # => [BX, BY, Q, U1, U2, ...]
    exec.phi_point
    # => [PHI_Q, Q, U1, U2, ...]

    exec.push_gy_digest
    # => [GY, PHI_Q, Q, U1, U2, ...]
    exec.push_gx_digest
    # => [GX, GY, PHI_Q, Q, U1, U2, ...]
    exec.phi_point
    # => [PHI_G, PHI_Q, Q, U1, U2, ...]

    exec.secp256k1::push_generator
    # => [G, PHI_G, PHI_Q, Q, U1, U2, ...]

    locaddr.0 mem_storew_le dropw
    # => [PHI_G, PHI_Q, Q, U1, U2, ...]
    locaddr.4 mem_storew_le dropw
    # => [PHI_Q, Q, U1, U2, ...]
    locaddr.8 mem_storew_le dropw
    # => [Q, U1, U2, ...]
    locaddr.12 mem_storew_le dropw
    # => [U1, U2, ...]
    locaddr.16 mem_storew_le dropw
    # => [U2, ...]
    locaddr.20 mem_storew_le dropw
    # => [...]

    # -- Term 1 (u1 = k1a + lambda*k1b): halves over G (loc[0]) and phi(G) (loc[4]). --

    # Half k1a, base G.
    exec.pull_signed_scalar
    # => [sign, MAG, ...]
    dup
    # => [sign, sign, MAG, ...]
    movdn.5
    # => [sign, MAG, sign2, ...]
    padw locaddr.0 mem_loadw_le
    # => [BASE, sign, MAG, sign2, ...]
    movup.4
    # => [sign, BASE, MAG, sign2, ...]
    exec.signed_base
    # => [SIGNED_BASE, MAG, sign2, ...]
    locaddr.24 mem_storew_le dropw
    # => [MAG, sign2, ...]
    dupw
    # => [MAG, MAG, sign2, ...]
    locaddr.28 mem_storew_le dropw
    # => [MAG, sign2, ...]
    movup.4
    # => [sign2, MAG, ...]
    exec.signed_hat
    # => [HAT_1A, ...]

    # Half k1b, base phi(G).
    exec.pull_signed_scalar
    # => [sign, MAG, HAT_1A, ...]
    dup
    # => [sign, sign, MAG, HAT_1A, ...]
    movdn.5
    # => [sign, MAG, sign2, HAT_1A, ...]
    padw locaddr.4 mem_loadw_le
    # => [BASE, sign, MAG, sign2, HAT_1A, ...]
    movup.4
    # => [sign, BASE, MAG, sign2, HAT_1A, ...]
    exec.signed_base
    # => [SIGNED_BASE, MAG, sign2, HAT_1A, ...]
    locaddr.32 mem_storew_le dropw
    # => [MAG, sign2, HAT_1A, ...]
    dupw
    # => [MAG, MAG, sign2, HAT_1A, ...]
    locaddr.36 mem_storew_le dropw
    # => [MAG, sign2, HAT_1A, ...]
    movup.4
    # => [sign2, MAG, HAT_1A, ...]
    exec.signed_hat
    # => [HAT_1B, HAT_1A, ...]

    padw locaddr.16 mem_loadw_le
    # => [U1, HAT_1B, HAT_1A, ...]
    movdnw.2
    # => [HAT_1B, HAT_1A, U1, ...]
    exec.push_lambda_digest
    # => [LAMBDA, HAT_1B, HAT_1A, U1, ...]
    exec.assert_recompose
    # => [...]

    # -- Term 2 (u2 = k2a + lambda*k2b): halves over Q (loc[12]) and phi(Q) (loc[8]). --

    # Half k2a, base Q.
    exec.pull_signed_scalar
    # => [sign, MAG, ...]
    dup
    # => [sign, sign, MAG, ...]
    movdn.5
    # => [sign, MAG, sign2, ...]
    padw locaddr.12 mem_loadw_le
    # => [BASE, sign, MAG, sign2, ...]
    movup.4
    # => [sign, BASE, MAG, sign2, ...]
    exec.signed_base
    # => [SIGNED_BASE, MAG, sign2, ...]
    locaddr.40 mem_storew_le dropw
    # => [MAG, sign2, ...]
    dupw
    # => [MAG, MAG, sign2, ...]
    locaddr.44 mem_storew_le dropw
    # => [MAG, sign2, ...]
    movup.4
    # => [sign2, MAG, ...]
    exec.signed_hat
    # => [HAT_2A, ...]

    # Half k2b, base phi(Q).
    exec.pull_signed_scalar
    # => [sign, MAG, HAT_2A, ...]
    dup
    # => [sign, sign, MAG, HAT_2A, ...]
    movdn.5
    # => [sign, MAG, sign2, HAT_2A, ...]
    padw locaddr.8 mem_loadw_le
    # => [BASE, sign, MAG, sign2, HAT_2A, ...]
    movup.4
    # => [sign, BASE, MAG, sign2, HAT_2A, ...]
    exec.signed_base
    # => [SIGNED_BASE, MAG, sign2, HAT_2A, ...]
    locaddr.48 mem_storew_le dropw
    # => [MAG, sign2, HAT_2A, ...]
    dupw
    # => [MAG, MAG, sign2, HAT_2A, ...]
    locaddr.52 mem_storew_le dropw
    # => [MAG, sign2, HAT_2A, ...]
    movup.4
    # => [sign2, MAG, HAT_2A, ...]
    exec.signed_hat
    # => [HAT_2B, HAT_2A, ...]

    # Drain the 3 zero felts `encode_signature` appends to pad its GLV advice output to a multiple
    # of 8 (`push_for_adv_pipe`'s requirement).
    adv_push drop
    adv_push drop
    adv_push drop
    # => [HAT_2B, HAT_2A, ...]

    padw locaddr.20 mem_loadw_le
    # => [U2, HAT_2B, HAT_2A, ...]
    movdnw.2
    # => [HAT_2B, HAT_2A, U2, ...]
    exec.push_lambda_digest
    # => [LAMBDA, HAT_2B, HAT_2A, U2, ...]
    exec.assert_recompose
    # => [...]

    # -- Resolve the 4-term MSM over the pair buffer at loc[24..56]. --
    push.4 locaddr.24
    # => [ptr, n, ...]
    exec.secp256k1::msm_mem
    # => [VERIFY_POINT, ...]
end

# INTERNAL PROCEDURES — STRAUS
# ================================================================================================
#
# `verify_point_straus` computes `R = u1*G + u2*Q` as a plain 2-base joint wNAF MSM, with no GLV
# endomorphism split. Cheaper than GLV for a single signature or a small batch, since it carries no
# per-signature endomorphism-image/table setup; GLV wins once enough signatures in one proof share
# its two cacheable bases (`G`, `phi(G)`) to amortize that setup.

#! Computes `R = u1*G + u2*Q` via the classic 2-base joint wNAF MSM.
#!
#! Advice: 7 trailing zero felts, padding `encode_signature`'s Straus output to a multiple of 8
#! (`push_for_adv_pipe`'s requirement).
#! Input:  [U1, Q, U2, SIG_R, ...]
#! Output: [VERIFY_POINT, SIG_R, ...]
proc verify_point_straus
    exec.secp256k1::push_generator
    # => [G, U1, Q, U2, SIG_R, ...]
    exec.secp256k1::msm2
    # => [VERIFY_POINT, SIG_R, ...]

    # Drain the 7 trailing zero felts `encode_signature` appends to pad its Straus advice output to
    # a multiple of 8 (`push_for_adv_pipe`'s requirement).
    adv_push drop
    adv_push drop
    adv_push drop
    adv_push drop
    adv_push drop
    adv_push drop
    adv_push drop
    # => [VERIFY_POINT, SIG_R, ...]
end

# INTERNAL PROCEDURES — ECDSA
# ================================================================================================

#! Computes ECDSA scalars U1 = z/s and U2 = r/s, keeping SIG_R for the final check.
#!
#! Input:  [Z_U32[8], pubkey_ptr, ...]
#! Advice: [SIG_R[8] | SIG_S[8] | ...]
#! Output: [U1_DIGEST, Q_DIGEST, U2_DIGEST, SIG_R_DIGEST, ...]
#!
#! Preconditions/provenance:
#! - Z_U32[8] is the Keccak256 message digest converted to little-endian scalar limbs;
#! - pubkey_ptr points to QX[8] || QY[8], already bound to PK_COMM by `verify`;
#! - SIG_R/S advice is untrusted and validated by `load_signature_k1`.
proc prepare_verify_inputs
    exec.k1_scalar::load_reduced_256
    # => [Z, pubkey_ptr, ...]

    movup.4
    # => [pubkey_ptr, Z, ...]
    exec.secp256k1::load_mem
    # => [Q, Z, ...]
    swapw
    # => [Z, Q, ...]

    exec.load_signature_k1
    # => [SIG_S, SIG_R, Z, Q, ...]

    exec.k1_scalar::inv
    # => [S_INV, SIG_R, Z, Q, ...]

    dupw
    movupw.3
    exec.k1_scalar::mul
    # => [U1 = Z*S_INV, S_INV, SIG_R, Q, ...]

    dupw.1
    dupw.3
    exec.k1_scalar::mul
    # => [U2 = SIG_R*S_INV, U1, S_INV, SIG_R, Q, ...]

    swapw.2
    # => [S_INV, U1, U2, SIG_R, Q, ...]
    dropw
    # => [U1, U2, SIG_R, Q, ...]

    movupw.3 swapw
    # => [U1, Q, U2, SIG_R, ...]
end

#! Loads SIG_R and SIG_S from advice as k1 scalar VALUE digests, checks SIG_R != 0,
#! and returns SIG_S on top because callers immediately invert SIG_S.
#!
#! Advice: [SIG_R[8] | SIG_S[8] | ...]
#! Output: [SIG_S_SCALAR_VALUE_DIGEST, SIG_R_SCALAR_VALUE_DIGEST, ...]
proc load_signature_k1
    exec.load_scalar_k1_from_advice
    # => [SIG_R, ...]

    exec.load_scalar_k1_from_advice
    # => [SIG_S, SIG_R, ...]

    # ECDSA requires SIG_R != 0 and SIG_S != 0.
    # Check SIG_R here. We do not check SIG_S here because k1_scalar::inv(SIG_S) traps on SIG_S = 0
    # and binds the inverse relation for nonzero SIG_S.
    dupw.1
    # => [SIG_R, SIG_S, SIG_R, ...]
    exec.k1_scalar::push_zero_digest
    # => [ZERO_DIGEST, SIG_R_COPY, SIG_S, SIG_R, ...]
    exec.word::eq
    # => [is_sig_r_zero, SIG_S, SIG_R, ...]
    assertz.err="invalid ECDSA signature: r is zero"
    # => [SIG_S, SIG_R, ...]
end

#! Loads one canonical k1 scalar from advice.
#!
#! Advice: [VALUE_LO_U32[4] | VALUE_HI_U32[4] | ...]
#! Output: [VALUE_SCALAR_DIGEST, ...]
proc load_scalar_k1_from_advice
    adv_pushw
    # => [VALUE_LO_U32[4], ...]
    adv_pushw
    # => [VALUE_HI_U32[4], VALUE_LO_U32[4], ...]
    swapw
    # => [VALUE_LO_U32[4], VALUE_HI_U32[4], ...]
    exec.k1_scalar::load
    # => [VALUE_SCALAR_DIGEST, ...]
end

#! Evaluates VERIFY_POINT once, rejects the identity, reduces x(VERIFY_POINT) modulo n, and
#! compares the resulting scalar-field expression against SIG_R.
#!
#! Input:  [VERIFY_POINT_DIGEST, SIG_R_SCALAR_VALUE_DIGEST, ...]
#! Output: [...]
#!
#! Preconditions/provenance:
#! - SIG_R_SCALAR_VALUE_DIGEST is a canonical k1 scalar VALUE digest, e.g. from load_signature_k1;
#! - secp256k1::eval binds VERIFY_POINT_DIGEST to the returned canonical curve VALUE payload;
#! - after identity rejection succeeds, X_OR_TRUE_DIGEST/Y_OR_TRUE_DIGEST are real coordinate digests.
proc assert_x_eq_scalar_k1
    exec.secp256k1::eval
    # => [VERIFY_POINT_VALUE_DIGEST, X_OR_TRUE_DIGEST, Y_OR_TRUE_DIGEST, SIG_R_SCALAR_VALUE_DIGEST, ...]

    # Reject identity at the curve VALUE-digest level. `eval` returns the canonical VALUE digest
    # alongside the coordinate payload, so direct comparison to the registered identity VALUE digest
    # is sound and avoids a second curve evaluation.
    exec.secp256k1::push_identity
    # => [IDENTITY_VALUE_DIGEST, VERIFY_POINT_VALUE_DIGEST, X_OR_TRUE_DIGEST, Y_OR_TRUE_DIGEST, SIG_R_SCALAR_VALUE_DIGEST, ...]
    exec.word::eq
    # => [is_identity, X_OR_TRUE_DIGEST, Y_OR_TRUE_DIGEST, SIG_R_SCALAR_VALUE_DIGEST, ...]
    assertz.err="invalid ECDSA verification point: identity"
    # => [X_DIGEST, Y_DIGEST, SIG_R_SCALAR_VALUE_DIGEST, ...]
    swapw dropw
    # => [X_DIGEST, SIG_R_SCALAR_VALUE_DIGEST, ...]

    # X_DIGEST is a canonical k1-base VALUE child of the proof-bound curve VALUE above. Open that
    # commitment directly; ordinary `eval` remains necessary for arbitrary expression digests.
    exec.k1_base::open_value
    # => [X_U32[8], SIG_R_SCALAR_VALUE_DIGEST, ...]
    exec.k1_scalar::load_reduced_256
    # => [X_SCALAR_DIGEST, SIG_R_SCALAR_VALUE_DIGEST, ...]

    swapw
    # => [SIG_R_SCALAR_VALUE_DIGEST, X_SCALAR_DIGEST, ...]
    exec.k1_scalar::is_eq_digest
    # => [x_matches_sig_r, ...]
    assert.err="ECDSA verification failed: x(VERIFY_POINT) != SIG_R"
    # => [...]
end

# INTERNAL PROCEDURES — BYTE OPS
# ================================================================================================

#! Stores a word as the eight little-endian u32 limbs used as the 32-byte Keccak message.
#!
#! Input:  [w0, w1, w2, w3, ptr, ...]
#! Output: [ptr, ...]
proc store_word_u32s_le
    swap u32split
    # => [w1_lo, w1_hi, w0, w2, w3, ptr, ...]
    movup.2 u32split
    # => [w0_lo, w0_hi, w1_lo, w1_hi, w2, w3, ptr, ...]
    dup.6 mem_storew_le dropw
    # => [w2, w3, ptr, ...]  (ptr[0..4] = [w0_lo, w0_hi, w1_lo, w1_hi])

    swap u32split
    # => [w3_lo, w3_hi, w2, ptr, ...]
    movup.2 u32split
    # => [w2_lo, w2_hi, w3_lo, w3_hi, ptr, ...]
    dup.4 add.4 mem_storew_le dropw
    # => [ptr, ...]  (ptr[4..8] = [w2_lo, w2_hi, w3_lo, w3_hi])
end

#! Reverses the byte order of a u32 limb.
#!
#! Input:  [x, ...]
#! Output: [byte_reverse(x), ...]
proc reverse_u32_bytes
    dup u32shr.8 push.0x00FF00FF u32and
    # => [(x >> 8) & 0x00ff00ff, x, ...]
    swap push.0x00FF00FF u32and mul.256
    # => [(x & 0x00ff00ff) << 8, shifted, ...]
    u32xor
    # => [x with adjacent bytes swapped, ...]

    dup u32shr.16
    # => [x >> 16, x, ...]
    swap u32shl.16
    # => [(x << 16) mod 2^32, x >> 16, ...]
    u32xor
    # => [byte_reverse(x), ...]
end
