#! Keccak256 hash procedures.
#!
#! These stack-returning core wrappers use bundled precompile-backed support internally for event
#! handling and deferred verification.

use miden::precompiles::crypto::hashes::keccak256

# ENCODING CONVENTIONS
# ================================================================================================
#
# This module uses the following notation for data representation:
# - VALUE_U32[n] = arrays of n u32 values, denoted as [v_0, ..., v_{n-1}]
# - VALUE_U8[n] = arrays of n u8 values, denoted as [b_0, ..., b_{n-1}]
# - Conversion: v_i = u32::from_le_bytes([b_{4i}, b_{4i+1}, b_{4i+2}, b_{4i+3}])
# - Fixed-size examples: DIGEST_U32[8] = [d_0, ..., d_7], INPUT_U8[32] = [b_0, ..., b_31]
# - DIGEST_U32[8] = [d_0, ..., d_7] = Keccak256(INPUT_U8[..])

# PROCEDURES
# ================================================================================================

#! Computes Keccak256 hash of data stored in memory.
#!
#! Input: [ptr, len_bytes, ...]
#! Output: [DIGEST_U32[8], ...]
#!
#! Where:
#! - ptr: word-aligned memory address containing INPUT_U32[len_u32] where len_u32=⌈len_bytes/4⌉
#! - len_bytes: number of bytes to hash
#! - INPUT_U32[len_u32] ~ INPUT_U8[len_bytes] with u32 packing (unused bytes in final u32 must be 0)
#! - DIGEST_U32[8] = [d_0, ..., d_7] = Keccak256(INPUT_U8[len_bytes])
@locals(8)
pub proc hash_bytes
    locaddr.0 movdn.2
    # => [ptr, len_bytes, out_ptr=loc[0], ...]
    dup.2 movdn.3
    # => [ptr, len_bytes, out_ptr=loc[0], out_ptr=loc[0], ...]

    exec.keccak256::hash_bytes_mem
    # => [out_ptr=loc[0], ...]  (DIGEST_U32[8] written to loc[0..8])

    # Reload digest limbs using the saved output pointer rather than reloading local words.
    padw dup.4 mem_loadw_le
    # => [DIGEST_LO_U32[4], out_ptr, ...]
    padw movup.8 add.4 mem_loadw_le swapw
    # => [DIGEST_U32[8], ...]
end

#! Computes Keccak256 hash of a single 256-bit input.
#!
#! Input: [INPUT_U32[8], ...]
#! Output: [DIGEST_U32[8], ...]
#!
#! Where
#! - DIGEST_U32[8] = [d_0, ..., d_7] = Keccak256(INPUT_U8[32])
#! - INPUT_U32[8] = [i_0, ..., i_7] = [INPUT_LO, INPUT_HI] ~ INPUT_U8[32] with u32 packing
@locals(8)
pub proc hash
    # Stage INPUT_U32[8] at loc[0..8], using the pointer as a short cursor and recovering the base.
    locaddr.0
    # => [out_ptr, INPUT_U32[8], ...]
    dup movdn.5
    # => [out_ptr, INPUT_LO_U32[4], out_ptr, INPUT_HI_U32[4], ...]
    mem_storew_le dropw add.4
    # => [out_ptr+4, INPUT_HI_U32[4], ...]
    dup movdn.5
    # => [out_ptr+4, INPUT_HI_U32[4], out_ptr+4, ...]
    mem_storew_le dropw sub.4
    # => [out_ptr=loc[0], ...]

    dup dup push.32 swap
    # => [in_ptr=loc[0], len_bytes=32, out_ptr=loc[0], out_ptr=loc[0], ...]
    exec.keccak256::hash_1_chunk_mem
    # => [out_ptr=loc[0], ...]  (DIGEST_U32[8] written to loc[0..8])

    # Reload digest limbs using the saved output pointer rather than reloading local words.
    padw dup.4 mem_loadw_le
    # => [DIGEST_LO_U32[4], out_ptr, ...]
    padw movup.8 add.4 mem_loadw_le swapw
    # => [DIGEST_U32[8], ...]
end

#! Merges two 256-bit digests via Keccak256 hash.
#!
#! Input: [INPUT_L_U32[8], INPUT_R_U32[8], ...]
#! Output: [DIGEST_U32[8], ...]
#!
#! Where
#! - INPUT_L_U32[8] = [l_0, ..., l_7] = [INPUT_L_LO, INPUT_L_HI] ~ INPUT_L_U8[32]
#! - INPUT_R_U32[8] = [r_0, ..., r_7] = [INPUT_R_LO, INPUT_R_HI] ~ INPUT_R_U8[32]
#! - DIGEST_U32[8] = [d_0, ..., d_7] = Keccak256(INPUT_L_U8[32] || INPUT_R_U8[32])
@locals(16)
pub proc merge
    # Stage INPUT_L || INPUT_R at loc[0..16], using locaddr.0 as a cursor and recovering the base.
    locaddr.0
    # => [out_ptr, INPUT_L_U32[8], INPUT_R_U32[8], ...]
    repeat.3
        dup movdn.5
        mem_storew_le dropw add.4
    end
    # => [out_ptr+12, INPUT_W3_U32[4], ...]
    dup movdn.5
    # => [out_ptr+12, INPUT_W3_U32[4], out_ptr+12, ...]
    mem_storew_le dropw sub.12
    # => [out_ptr=loc[0], ...]

    dup dup push.64 swap
    # => [in_ptr=loc[0], len_bytes=64, out_ptr=loc[0], out_ptr=loc[0], ...]
    exec.keccak256::hash_2_chunks_mem
    # => [out_ptr=loc[0], ...]  (DIGEST_U32[8] written to loc[0..8])

    # Reload digest limbs using the saved output pointer rather than reloading local words.
    padw dup.4 mem_loadw_le
    # => [DIGEST_LO_U32[4], out_ptr, ...]
    padw movup.8 add.4 mem_loadw_le swapw
    # => [DIGEST_U32[8], ...]
end
