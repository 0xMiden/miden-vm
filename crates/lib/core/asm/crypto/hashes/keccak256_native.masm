# ===== ABSORB BLOCK =============================================================================

#! XORs one rate-sized block (17 lanes = 34 u32 felts = 136 bytes) of `src`
#! into the rate portion of `state`. Per FIPS 202, sec. B.2: each rate lane is
#! a 64-bit little-endian-packed value taken from 8 consecutive input bytes.
#! Within the lane, the lo half (bits 0..32) lives at the lower address; this
#! matches the rest of the state layout.
#!
#! Stack transition:
#!   [state_ptr, src_ptr, ...]  ->  [...]
#!
#! Local memory layout (4 felts):
#!   0 : state_ptr cache
#!   1 : src_ptr cache
@locals(4)
proc absorb_block
    loc_store.0                                          # cache state_ptr
    loc_store.1                                          # cache src_ptr

    # For each i in 0..34: state[i] ^= src[i]. (34 unrolled iterations.)
    loc_load.0  add.0    dup   mem_load     loc_load.1  add.0    mem_load   u32xor   swap   mem_store
    loc_load.0  add.1    dup   mem_load     loc_load.1  add.1    mem_load   u32xor   swap   mem_store
    loc_load.0  add.2    dup   mem_load     loc_load.1  add.2    mem_load   u32xor   swap   mem_store
    loc_load.0  add.3    dup   mem_load     loc_load.1  add.3    mem_load   u32xor   swap   mem_store
    loc_load.0  add.4    dup   mem_load     loc_load.1  add.4    mem_load   u32xor   swap   mem_store
    loc_load.0  add.5    dup   mem_load     loc_load.1  add.5    mem_load   u32xor   swap   mem_store
    loc_load.0  add.6    dup   mem_load     loc_load.1  add.6    mem_load   u32xor   swap   mem_store
    loc_load.0  add.7    dup   mem_load     loc_load.1  add.7    mem_load   u32xor   swap   mem_store
    loc_load.0  add.8    dup   mem_load     loc_load.1  add.8    mem_load   u32xor   swap   mem_store
    loc_load.0  add.9    dup   mem_load     loc_load.1  add.9    mem_load   u32xor   swap   mem_store
    loc_load.0  add.10   dup   mem_load     loc_load.1  add.10   mem_load   u32xor   swap   mem_store
    loc_load.0  add.11   dup   mem_load     loc_load.1  add.11   mem_load   u32xor   swap   mem_store
    loc_load.0  add.12   dup   mem_load     loc_load.1  add.12   mem_load   u32xor   swap   mem_store
    loc_load.0  add.13   dup   mem_load     loc_load.1  add.13   mem_load   u32xor   swap   mem_store
    loc_load.0  add.14   dup   mem_load     loc_load.1  add.14   mem_load   u32xor   swap   mem_store
    loc_load.0  add.15   dup   mem_load     loc_load.1  add.15   mem_load   u32xor   swap   mem_store
    loc_load.0  add.16   dup   mem_load     loc_load.1  add.16   mem_load   u32xor   swap   mem_store
    loc_load.0  add.17   dup   mem_load     loc_load.1  add.17   mem_load   u32xor   swap   mem_store
    loc_load.0  add.18   dup   mem_load     loc_load.1  add.18   mem_load   u32xor   swap   mem_store
    loc_load.0  add.19   dup   mem_load     loc_load.1  add.19   mem_load   u32xor   swap   mem_store
    loc_load.0  add.20   dup   mem_load     loc_load.1  add.20   mem_load   u32xor   swap   mem_store
    loc_load.0  add.21   dup   mem_load     loc_load.1  add.21   mem_load   u32xor   swap   mem_store
    loc_load.0  add.22   dup   mem_load     loc_load.1  add.22   mem_load   u32xor   swap   mem_store
    loc_load.0  add.23   dup   mem_load     loc_load.1  add.23   mem_load   u32xor   swap   mem_store
    loc_load.0  add.24   dup   mem_load     loc_load.1  add.24   mem_load   u32xor   swap   mem_store
    loc_load.0  add.25   dup   mem_load     loc_load.1  add.25   mem_load   u32xor   swap   mem_store
    loc_load.0  add.26   dup   mem_load     loc_load.1  add.26   mem_load   u32xor   swap   mem_store
    loc_load.0  add.27   dup   mem_load     loc_load.1  add.27   mem_load   u32xor   swap   mem_store
    loc_load.0  add.28   dup   mem_load     loc_load.1  add.28   mem_load   u32xor   swap   mem_store
    loc_load.0  add.29   dup   mem_load     loc_load.1  add.29   mem_load   u32xor   swap   mem_store
    loc_load.0  add.30   dup   mem_load     loc_load.1  add.30   mem_load   u32xor   swap   mem_store
    loc_load.0  add.31   dup   mem_load     loc_load.1  add.31   mem_load   u32xor   swap   mem_store
    loc_load.0  add.32   dup   mem_load     loc_load.1  add.32   mem_load   u32xor   swap   mem_store
    loc_load.0  add.33   dup   mem_load     loc_load.1  add.33   mem_load   u32xor   swap   mem_store
end

# ===== KECCAK-256 (FULL SPONGE) =================================================================

#! Computes Keccak-256 of a byte buffer stored as u32-packed little-endian
#! felts in memory. Input convention matches the precompile path
#! (`hash_bytes` in `keccak256.masm`):
#!
#! - `src_ptr` points to `ceil(len_bytes / 4)` u32 felts.
#! - Each u32 packs four little-endian bytes: u32[k] = b[4k] | (b[4k+1] << 8) | ...
#! - If `len_bytes` is not a multiple of 4, the trailing bytes of the final
#!   u32 must be zero (the proc relies on this when ORing the domain byte in).
#!
#! Stack transition:
#!   [src_ptr, len_bytes, ...]  ->  [d_0, d_1, ..., d_7, ...]
#!
#! Where `d_0..d_7` are 8 u32 felts forming the 32-byte digest in little-endian
#! lane order (`d_k = state[k]` after the final permutation): bytes 0..32 of the
#! digest correspond to (d_0 bytes 0..4) || (d_1 bytes 0..4) || ... || (d_7
#! bytes 0..4), matching `Keccak256::hash` output.
#!
#! Local memory layout (96 felts):
#!   0..50   : sponge state (50 felts).
#!   50, 51  : unused (alignment padding before scratch).
#!   52..86  : final-block scratch (34 felts; word-aligned at 52).
#!   86..96  : runtime counters --
#!     86 : src_ptr (current; advanced by 34 per absorbed block)
#!     87 : remaining bytes (decremented by 136 per absorbed block)
#!     88 : final-block u32 count (= ceil(remaining / 4))
#!     89 : copy-loop counter i
#!     90 : final-block q = remaining / 4
#!     91 : final-block r = remaining mod 4
#!     92..96 : unused
@locals(96)
pub proc keccak256_bytes
    # ----- Phase 1: cache args and zero the state -----
    u32assert2                                           # range-check len_bytes (and src_ptr, free)
    loc_store.86                                         # src_ptr (current)
    loc_store.87                                         # remaining bytes

    # Zero state slots 0..50. One shared `padw`; each `loc_storew_le` writes the zero
    # word and leaves it on stack for the next store; final `dropw` clears it.
    padw
    loc_storew_le.0
    loc_storew_le.4
    loc_storew_le.8
    loc_storew_le.12
    loc_storew_le.16
    loc_storew_le.20
    loc_storew_le.24
    loc_storew_le.28
    loc_storew_le.32
    loc_storew_le.36
    loc_storew_le.40
    loc_storew_le.44
    dropw
    push.0  loc_store.48
    push.0  loc_store.49

    # ----- Phase 2: absorb full blocks while remaining >= 136 -----
    loc_load.87  u32gte.136
    while.true
        # absorb_block(state_ptr = locaddr.0, src_ptr = mem[86]).
        loc_load.86   locaddr.0   exec.absorb_block
        locaddr.0     exec.permute
        # Advance src_ptr by 34 (u32 indices), remaining by -136 (bytes).
        loc_load.86   add.34    loc_store.86
        loc_load.87   sub.136   loc_store.87
        # Recompute loop condition.
        loc_load.87   u32gte.136
    end

    # ----- Phase 3: final block -----
    # Zero scratch[52..86] so subsequent partial copy + OR yields the canonical
    # padded block.
    padw
    loc_storew_le.52
    loc_storew_le.56
    loc_storew_le.60
    loc_storew_le.64
    loc_storew_le.68
    loc_storew_le.72
    loc_storew_le.76
    loc_storew_le.80
    dropw
    push.0  loc_store.84
    push.0  loc_store.85

    # num_u32s = ceil(remaining / 4) = (remaining + 3) >> 2.
    loc_load.87  add.3   u32shr.2   loc_store.88

    # Copy src[0..num_u32s] into scratch[52..52+num_u32s].
    push.0  loc_store.89                                  # i = 0
    loc_load.89   loc_load.88   u32lt                     # i < num_u32s ?
    while.true
        # scratch[52 + i] = src[src_ptr + i].
        loc_load.86  loc_load.89  add   mem_load          # [src[i]]
        locaddr.52   loc_load.89   add                    # [scratch_addr, src[i]]
        mem_store
        # i += 1.
        loc_load.89  add.1  loc_store.89
        loc_load.89  loc_load.88   u32lt
    end

    # Apply padding to scratch:
    #   scratch[q]  |= 0x01 << (8 * r)      (domain byte)
    #   scratch[33] |= 0x80000000           (final-bit flag)
    # where q = remaining / 4, r = remaining mod 4.
    loc_load.87   u32shr.2          loc_store.90          # q
    loc_load.87   push.3   u32and   loc_store.91          # r

    # pad_mask = 0x01 << (8 * r). r in {0, 1, 2, 3} => mask in {1, 0x100, 0x10000, 0x1000000}.
    loc_load.91   eq.0
    if.true
        push.1
    else
        loc_load.91   eq.1
        if.true
            push.256                                       # 0x100
        else
            loc_load.91   eq.2
            if.true
                push.65536                                  # 0x10000
            else
                push.16777216                               # 0x1000000
            end
        end
    end
    # Stack: [pad_mask]

    # scratch[q] |= pad_mask.
    locaddr.52   loc_load.90   add        # [scratch_q_addr, pad_mask]
    dup   mem_load                        # [val, addr, pad_mask]
    movup.2   u32or                       # [val | pad_mask, addr]
    swap   mem_store

    # scratch[33] |= 0x80000000.
    locaddr.85   dup   mem_load           # [val, addr]   (slot 52 + 33 = 85)
    push.2147483648   u32or               # [val | 0x80000000, addr]
    swap   mem_store

    # Absorb scratch into state, permute.
    locaddr.52   locaddr.0   exec.absorb_block
    locaddr.0    exec.permute

    # ----- Phase 4: squeeze -----
    # Push state[0..8] onto stack so that state[0] (= d_0) ends up on top
    # and state[7] (= d_7) is deepest.
    loc_load.7
    loc_load.6
    loc_load.5
    loc_load.4
    loc_load.3
    loc_load.2
    loc_load.1
    loc_load.0
end
