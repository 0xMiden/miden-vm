use miden::core::crypto::hashes::poseidon2
use miden::core::stark::constants
use miden::core::pcs::fri::helper

#! Checks that, for a query with index p at layer i, the folding procedure to create layer (i + 1)
#! was performed correctly. This also advances layer_ptr by 8 to point to the next query layer.
#!
#! Input:  [layer_ptr, layer_ptr, poe, p, e0, e1, layer_ptr, rem_ptr, x, x, x, x, x, x, x, x, ...]
#! Output: [is_not_last_layer, layer_ptr+8, layer_ptr+8, poe^4, f_pos, ne0, ne1, layer_ptr+8, rem_ptr, x, x, x, x, x, x, x, x, ...]
pub proc verify_query_layer

    # Load layer commitment C and layer metadata.
    swapdw
    movup.8
    add.4
    mem_loadw_le   # load [d_size, t_depth, a0, a1] from layer_ptr + 4
    swapw
    movup.8
    mem_loadw_le   # load C from layer_ptr
    # => [C, d_size, t_depth, a0, a1, poe, p, e0, e1, layer_ptr, rem_ptr, ...]

    # Verify the Merkle auth path for (index = f_pos, depth = t_depth, root = C).
    swapw.2             # [poe, p, e0, e1, d_size, t_depth, a0, a1, C, layer_ptr, rem_ptr, ...]
    swap                # [p, poe, e0, e1, d_size, t_depth, a0, a1, C, layer_ptr, rem_ptr, ...]
    movup.4             # [d_size, p, poe, e0, e1, t_depth, a0, a1, C, layer_ptr, rem_ptr, ...]

    # Split the query position into the Merkle leaf position and the fold-4 coset.
    u32divmod           # [f_pos, coset, poe, e0, e1, t_depth, a0, a1, C, layer_ptr, rem_ptr, ...]
    # => [f_pos, coset, poe, e0, e1, t_depth, a0, a1, C, layer_ptr, rem_ptr, ...]
    movup.5
    movupw.2
    dup.5

    movup.5             # [t_depth, f_pos, C, f_pos, coset, poe, e0, e1, a0, a1, layer_ptr, rem_ptr, ...]
    mtree_get           # [V, C, f_pos, coset, poe, e0, e1, a0, a1, layer_ptr, rem_ptr, ...]
    adv.push_mapval
    swapw
    # => [C, V, f_pos, coset, poe, e0, e1, a0, a1, layer_ptr, rem_ptr, ...]

    # Hash the opened row. `adv_pipe` caches the row in tmp3/tmp4 and overwrites the
    # first 8 stack elements.
    exec.constants::tmp3
    movdn.4
    padw
    swapw
    padw
    adv_pipe
    exec.poseidon2::permute
    # => [T0, T1, T2, ptr, V, f_pos, coset, poe, e0, e1, a0, a1, layer_ptr, rem_ptr, ..]

    # Assert that the opened row hashes to the committed leaf.
    swapw
    swapw.3
    drop
    movup.3
    assert_eq
    movup.2
    assert_eq
    assert_eq
    movup.9
    assert_eq

    # Load the opened row from memory.
    exec.constants::tmp4
    mem_loadw_le
    swapw
    exec.constants::tmp3
    mem_loadw_le
    # => [v0, ..., v7, f_pos, coset, poe, e0, e1, a0, a1, layer_ptr, rem_ptr, ...]
    fri_ext2fold4
    # => [x, x, x, x, x, x, x, x, layer_ptr+8, layer_ptr+8, poe^4, f_pos, ne0, ne1, layer_ptr+8, rem_ptr, ...]

    # Prepare for the next layer.
    swapdw
    # => [layer_ptr+8, layer_ptr+8, poe^4, f_pos, ne0, ne1, layer_ptr+8, rem_ptr, x, x, x, x, x, x, x, x, ...]
    dup.7
    # => [rem_ptr, layer_ptr+8, layer_ptr+8, poe^4, f_pos, ne0, ne1, layer_ptr+8, rem_ptr, ...]
    dup.1
    # => [layer_ptr+8, rem_ptr, layer_ptr+8, layer_ptr+8, poe^4, f_pos, ne0, ne1, layer_ptr+8, rem_ptr, ...]
    neq
    # => [is_not_last_layer, layer_ptr+8, layer_ptr+8, poe^4, f_pos, ne0, ne1, layer_ptr+8, rem_ptr, x, x, x, x, x, x, x, x, ...]
end

#! Verifies one FRI query.
#!
#! This procedure is specialized to the case when the remainder polynomial, used in the final check,
#! is expected to have degree at most 64.
#! This procedure is exactly the same as `verify_query_128` except for the remainder polynomial check,
#! thus any change to one procedure will imply an equivalent change to the other one.
#!
#! Input:  [poe, p, e0, e1, layer_ptr, rem_ptr, ...]
#! Output: [x, x, x, x, x, x, x, x, x, x, x, x, ...] (12 ignored elements)
#!
#! - poe is g^p for the current FRI layer.
#! - p is a query index at the first layer.
#! - (e0, e1) is an extension field element corresponding to the value of the first layer at index p.
#! - layer_ptr is the memory address of the layer data (Merkle tree root, alpha etc.) for the next
#!   layer.
#! - rem_ptr is the memory address of the remainder polynomial.
#!
pub proc verify_query_64

    # Prepare the stack to match the shape expected by `verify_query_layer`.
    dup.5
    dup.5
    padw
    padw
    swapdw
    dup
    dup
    movup.3
    neq
    # => [?, layer_ptr, layer_ptr, poe, p, e0, e1, layer_ptr, rem_ptr, 0, 0, 0, 0, 0, 0, 0, 0, ...]

    # verify correctness of layer folding
    while.true
        exec.verify_query_layer
    end
    # => [rem_ptr, rem_ptr, poe^(2^n), f_pos, ne0, ne1, rem_ptr, rem_ptr, x, x, x, x, x, x, x, x, ...]

    movup.2
    push.0.0.0 movup.3 exec.constants::tmp2 mem_storew_le dropw
    # => [rem_ptr, rem_ptr, f_pos, ne0, ne1, rem_ptr, rem_ptr, x, x, x, x, x, x, x, x, ...]

    push.0 exec.constants::tmp1 mem_loadw_le
    # => [P, ne0, ne1, rem_ptr, rem_ptr, x, x, x, x, x, x, x, x, ...]

    swapw swapdw
    # => [x, x, x, x, x, x, x, x, ne0, ne1, rem_ptr, rem_ptr, P, ...]

    exec.helper::evaluate_fri_remainder_poly_max_degree_plus_1_half
    # => [x, x, x, x, x, x, x, x, ne0, ne1, rem_ptr, rem_ptr, P, ...]

    swapdw
    # => [ne0, ne1, rem_ptr, rem_ptr, P, x, x, x, x, x, x, x, x, ...]
    movup.6 assert_eq
    movup.5 assert_eq
    # => [X, x, x, x, x, x, x, x, x, ...]
end

#! Verifies one FRI query.
#!
#! This procedure is specialized to the case when the remainder polynomial, used in the final check,
#! is expected to have degree at most 128.
#! This procedure is exactly the same as `verify_query_64` except for the remainder polynomial check,
#! thus any change to one procedure will imply an equivalent change to the other one.
#!
#! Input:  [poe, p, e0, e1, layer_ptr, rem_ptr, ...]
#! Output: [x, x, x, x, x, x, x, x, x, x, x, x, ...] (12 ignored elements)
#!
#! - poe is g^p for the current FRI layer.
#! - p is a query index at the first layer.
#! - (e0, e1) is an extension field element corresponding to the value of the first layer at index p.
#! - layer_ptr is the memory address of the layer data (Merkle tree root, alpha etc.) for the next
#!   layer.
#! - rem_ptr is the memory address of the remainder polynomial.
#!
pub proc verify_query_128

    # Prepare the stack to match the shape expected by `verify_query_layer`.
    dup.5
    dup.5
    padw
    padw
    swapdw
    dup
    dup
    movup.3
    neq
    # => [?, layer_ptr, layer_ptr, poe, p, e0, e1, layer_ptr, rem_ptr, 0, 0, 0, 0, 0, 0, 0, 0, ...]

    # verify correctness of layer folding
    while.true
        exec.verify_query_layer
    end
    # => [rem_ptr, rem_ptr, poe^(2^n), f_pos, ne0, ne1, rem_ptr, rem_ptr, x, x, x, x, x, x, x, x, ...]

    movup.2
    push.0.0.0 movup.3 exec.constants::tmp2 mem_storew_le dropw
    # => [rem_ptr, rem_ptr, f_pos, ne0, ne1, rem_ptr, rem_ptr, x, x, x, x, x, x, x, x, ...]

    push.0 exec.constants::tmp1 mem_loadw_le
    # => [P, ne0, ne1, rem_ptr, rem_ptr, x, x, x, x, x, x, x, x, ...]

    swapw swapdw
    # => [x, x, x, x, x, x, x, x, ne0, ne1, rem_ptr, rem_ptr, P, ...]

    exec.helper::evaluate_fri_remainder_poly_max_degree_plus_1
    # => [x, x, x, x, x, x, x, x, ne0, ne1, rem_ptr, rem_ptr, P, ...]
    swapdw
    # => [ne0, ne1, rem_ptr, rem_ptr, P, x, x, x, x, x, x, x, x, ...]
    movup.6 assert_eq
    movup.5 assert_eq
    # => [X, x, x, x, x, x, x, x, x, ...]
end


#! Verifies a FRI proof where the proof was generated over the quadratic extension of the base
#! field and layer folding was performed using folding factor 4 when the degree of the remainder
#! polynomial is less than 64.
#! This procedure is exactly the same as `verify_128` except for the remainder polynomial check,
#! thus any change to one procedure will imply an equivalent change to the other one.
#!
#! Input:  [query_ptr, layer_ptr, rem_ptr, g, ...]
#! Output: [...]
#!
#! - query_ptr is a pointer to a list of tuples of the form (poe, p, e0, e1) where poe is equal
#!   to g^p with g being the initial FRI domain generator. p is the query index at the first layer
#!   and (e0, e1) is an extension field element corresponding to the value of the first layer at index p.
#! - layer_ptr is a pointer to the first layer commitment denoted throughout the code by C.
#!   layer_ptr + 1 points to the first [alpha0, alpha1, t_depth, d_size] where d_size is the size
#!   of initial domain divided by 4, t_depth is the depth of the Merkle tree commitment to the
#!   first layer and (alpha0, alpha1) is the first challenge used in folding the first layer.
#!   Both t_depth and d_size are expected to be smaller than 2^32. Otherwise, the result of
#!   this procedure is undefined.
#! - rem_ptr is a pointer to the first tuple of two consecutive degree 2 extension field
#!   elements making up the remainder polynomial. This procedure is specialized to the case when
#!   the degree of the latter is less than 64.
#!
#! The memory referenced above is used contiguously, as follows:
#!
#!   [query_ptr ... layer_ptr ... rem_ptr ...]
#!
#! This means for example that:
#! 1. rem_ptr - 1 points to the last (alpha0, alpha1, t_depth, d_size) tuple.
#! 2. layer_ptr - 1 points to the last (poe, p, e0, e1) tuple.
#!
proc verify_64

    # Store [query_ptr, layer_ptr, rem_ptr, g] to keep track of all queries.
    exec.constants::fri_verify_state_ptr mem_storew_le

    # [(query_ptr == layer_ptr), query_ptr, layer_ptr, rem_ptr, g]
    dup
    dup.2
    neq

    # Save a word containing a fresh accumulator for Horner evaluating the remainder polynomial,
    # a pointer to the evaluation point and a pointer to the location of the polynomial.
    push.0.0
    exec.constants::tmp2 exec.constants::get_remainder_poly_address
    exec.constants::tmp1 mem_storew_le
    movup.4

    while.true
        # Load [poe, p, e0, e1] for the next query.
        movup.4
        mem_loadw_le
        # => [poe, p, e0, e1, layer_ptr, rem_ptr, g, ...]

        # Verify query p.
        exec.verify_query_64

        # Prepare for the next query.
        # => [x, x, x, x, x, x, x, x, x, x, x, x, g, ...]
        dropw drop
        # => [x, x, x, x, x, x, x, g, ...]
        exec.constants::fri_verify_state_ptr mem_loadw_le
        add.4
        exec.constants::fri_verify_state_ptr mem_storew_le
        swapw
        # => [x, x, x, x, query_ptr + 4, layer_ptr, rem_ptr, g, ...]
        dup.5
        dup.5
        neq
        # => [?, x, x, x, x, query_ptr + 4, layer_ptr, rem_ptr, g, ...]
    end
    # => [x, x, x, x, x, x, x, x, ...]

    dropw dropw
end

#! Verifies a FRI proof where the proof was generated over the quadratic extension of the base
#! field and layer folding was performed using folding factor 4 when the degree of the remainder
#! polynomial is less than 128.
#! This procedure is exactly the same as `verify_64` except for the remainder polynomial check,
#! thus any change to one procedure will imply an equivalent change to the other one.
#!
#! Input:  [query_ptr, layer_ptr, rem_ptr, g, ...]
#! Output: [...]
#!
#! - query_ptr is a pointer to a list of tuples of the form (poe, p, e0, e1) where poe is equal
#!   to g^p with g being the initial FRI domain generator. p is the query index at the first layer
#!   and (e0, e1) is an extension field element corresponding to the value of the first layer at index p.
#! - layer_ptr is a pointer to the first layer commitment denoted throughout the code by C.
#!   layer_ptr + 1 points to the first [alpha0, alpha1, t_depth, d_size] where d_size is the size
#!   of initial domain divided by 4, t_depth is the depth of the Merkle tree commitment to the
#!   first layer and (alpha0, alpha1) is the first challenge used in folding the first layer.
#!   Both t_depth and d_size are expected to be smaller than 2^32. Otherwise, the result of
#!   this procedure is undefined.
#! - rem_ptr is a pointer to the first tuple of two consecutive degree 2 extension field
#!   elements making up the remainder polynomial. This procedure is specialized to the case when
#!   the degree of the latter is less than 128.
#!
#! The memory referenced above is used contiguously, as follows:
#!
#!   [query_ptr ... layer_ptr ... rem_ptr ...]
#!
#! This means for example that:
#! 1. rem_ptr - 1 points to the last (alpha0, alpha1, t_depth, d_size) tuple.
#! 2. layer_ptr - 1 points to the last (poe, p, e0, e1) tuple.
#!
proc verify_128

    # Store [query_ptr, layer_ptr, rem_ptr, g] to keep track of all queries.
    exec.constants::fri_verify_state_ptr mem_storew_le

    # [(query_ptr == layer_ptr), query_ptr, layer_ptr, rem_ptr, g]
    dup
    dup.2
    neq

    # Save a word containing a fresh accumulator for Horner evaluating the remainder polynomial,
    # a pointer to the evaluation point and a pointer to the location of the polynomial.
    push.0.0
    exec.constants::tmp2 exec.constants::get_remainder_poly_address
    exec.constants::tmp1 mem_storew_le
    movup.4

    while.true
        # Load [poe, p, e0, e1] for the next query.
        movup.4
        mem_loadw_le
        # => [poe, p, e0, e1, layer_ptr, rem_ptr, g, ...]

        # Verify query p.
        exec.verify_query_128

        # Prepare for the next query.
        # => [x, x, x, x, x, x, x, x, x, x, x, x, g, ...]
        dropw drop
        # => [x, x, x, x, x, x, x, g, ...]
        exec.constants::fri_verify_state_ptr mem_loadw_le
        add.4
        exec.constants::fri_verify_state_ptr mem_storew_le
        swapw
        # => [x, x, x, x, query_ptr + 4, layer_ptr, rem_ptr, g, ...]
        dup.5
        dup.5
        neq
        # => [?, x, x, x, x, query_ptr + 4, layer_ptr, rem_ptr, g, ...]
    end
    # => [x, x, x, x, x, x, x, x, ...]

    dropw dropw
end

#! Verifies a FRI proof where the proof was generated over the quadratic extension of the base
#! field and layer folding was performed using folding factor 4.
#!
#! Input:  [...]
#! Output: [...]
#!
pub proc verify
    # Get domain generator and pointer to the remainder codeword.
    exec.constants::get_lde_domain_generator
    exec.constants::get_remainder_poly_address
    # => [remainder_poly_ptr, g, ...]

    # Get the pointer to the first layer commitment.
    exec.constants::fri_com_ptr
    # => [fri_layer_ptr, remainder_poly_ptr, g, ...]

    # Get the pointer to the first FRI query.
    exec.constants::get_fri_queries_address
    # => [query_ptr, fri_layer_ptr, remainder_poly_ptr, g, ...]

    dup dup.2 u32assert2 u32lt assert.err="fri query region must be non-empty"

    exec.constants::get_remainder_poly_size
    exec.helper::get_fri_remainder_poly_max_degree_plus_1_half
    eq

    if.true
        exec.verify_64
    else
        exec.verify_128
    end
    # => [...]
end
