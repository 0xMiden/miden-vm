use miden::core::crypto::hashes::poseidon2
use miden::core::stark::random_coin
use miden::core::stark::constants

# CONSTANTS
# =================================================================================================

# General constants
const FRI_REMAINDER_CODEWORD_MAX_SIZE_HALF = 512
const FRI_REMAINDER_CODEWORD_MAX_SIZE = 1024
const FRI_REMAINDER_CODEWORD_MAX_SIZE_HALF_LOG = 9
const FRI_REMAINDER_CODEWORD_MAX_SIZE_LOG = 10
const FRI_REMAINDER_POLY_MAX_DEGREE_PLUS_1_HALF = 64
const FRI_REMAINDER_POLY_MAX_DEGREE_PLUS_1 = 128

# CONSTANTS GETTERS
# =================================================================================================

pub proc get_fri_remainder_codeword_max_size
    push.FRI_REMAINDER_CODEWORD_MAX_SIZE
end

pub proc get_fri_remainder_poly_max_degree_plus_1_half
    push.FRI_REMAINDER_POLY_MAX_DEGREE_PLUS_1_HALF
end

pub proc get_fri_remainder_poly_max_degree_plus_1
    push.FRI_REMAINDER_POLY_MAX_DEGREE_PLUS_1
end

# HELPERS
# =================================================================================================

#! Loads FRI remainder polynomial of degree strictly less than `(max_degree + 1) / 2`.
proc load_fri_remainder_poly_max_degree_plus_1_half
    repeat.16
        adv_pipe exec.poseidon2::permute
    end
end

#! Loads FRI remainder polynomial of degree strictly less than `max_degree + 1`.
proc load_fri_remainder_poly_max_degree_plus_1
    repeat.32
        adv_pipe exec.poseidon2::permute
    end
end

#! Evaluates FRI remainder polynomial of degree strictly less than `(max_degree + 1) / 2`.
pub proc evaluate_fri_remainder_poly_max_degree_plus_1_half
    repeat.16
        mem_stream
        horner_eval_ext
    end
end

#! Evaluates FRI remainder polynomial of degree strictly less than `max_degree + 1`.
pub proc evaluate_fri_remainder_poly_max_degree_plus_1
    repeat.32
        mem_stream
        horner_eval_ext
    end
end

#! Compute the number of FRI layers given log2 of the size of LDE domain. It also computes the
#! LDE domain generator and, from it, the trace generator and store these for later use.
#!
#! Input: [...]
#! Output: [num_fri_layers, ...]
#! Cycles: 45
pub proc generate_fri_parameters
    # Load FRI verifier data
    padw exec.constants::get_lde_domain_info_word
    #=> [lde_size, log(lde_size), lde_g, 0, ...] (6 cycles)

    # Compute the number of FRI layers
    dup
    dup.2
    dup
    is_odd
    if.true
        push.FRI_REMAINDER_CODEWORD_MAX_SIZE_HALF
        swap
        push.FRI_REMAINDER_CODEWORD_MAX_SIZE_HALF_LOG sub
        div.2
    else
        push.FRI_REMAINDER_CODEWORD_MAX_SIZE
        swap
        push.FRI_REMAINDER_CODEWORD_MAX_SIZE_LOG sub
        div.2
    end
    # => [num_fri_layers, remainder_size, lde_size, lde_size, log2(lde_size), domain_gen, 0, ...] (12 cycles)

    exec.constants::set_num_fri_layers
    div.8
    exec.constants::set_remainder_poly_size
    # => [lde_size, lde_size, log2(lde_size), domain_gen, 0, ...] (7 cycles)

    dropw
    drop
    # => [...] (5 cycles)
end

#! Get FRI layer commitments and reseed with them in order to draw folding challenges i.e. alphas.
#!
#! Input: [...]
#! Output: [...]
#! Cycles: 21 + 225 * num_fri_layers
pub proc load_fri_layer_commitments
    # We need to store the current FRI layer LDE domain size and its logarithm.
    padw exec.constants::get_lde_domain_info_word
    exec.constants::tmp1 mem_storew_le
    # => [Y, ...] where `Y` is as "garbage" word

    # Address containing the first layer commitment
    push.0.0
    exec.constants::fri_com_ptr
    exec.constants::get_num_fri_layers
    # => [num_layers, ptr_layer, y, y, Y, ...] where `y` are considered as "garbage" values

    dup
    push.0
    neq
    while.true
        swapw
        adv_loadw
        # => [COM, num_layers, ptr_layer, y, y, ...]

        # Save FRI layer commitment
        dup.5
        add.4
        swap.6
        mem_storew_le
        #=> [COM, num_layers, ptr_layer + 4, y, y, ...]

        # Reseed with commitment and absorb per-round PoW witness in one shot.
        adv_push.1
        exec.random_coin::reseed_with_felt
        # => [num_layers, ptr_layer + 4, y, y, ...]

        # Verify per-round FRI folding PoW and sample folding challenge in one shot.
        # Reads folding_pow_bits from memory. Bypasses buffer API since sponge state
        # is known after reseed_with_felt.
        exec.random_coin::sample_folding_pow_and_ext
        #=> [a0, a1, num_layers, ptr_layer + 4, y, y, ...]
        padw
        exec.constants::tmp1 mem_loadw_le
        # => [lde_size, log2(lde_size), lde_generator, 0, a0, a1, Y, num_layers, ptr_layer + 4, y, y, ...]

        # Compute and save to memory new lde_size and its new logarithm
        div.4
        swap
        sub.2
        swap
        exec.constants::tmp1 mem_storew_le
        # => [lde_size / 4, log2(lde_size) - 2, lde_generator, 0, a0, a1, num_layers, ptr_layer + 4, y, y, ...]

        # Move the pointer higher up the stack
        movup.2 drop
        movup.2 drop
        # => [lde_size / 4, log2(lde_size) - 2, a0, a1, num_layers, ptr_layer + 4, y, y, ...]
        #swap
        # => [log2(lde_size) - 2, lde_size / 4, a1, a0, num_layers, ptr_layer + 4, y, y, ...]
        #movup.2 movup.3
        # => [a0, a1, log2(lde_size) - 2, lde_size / 4, num_layers, ptr_layer + 4, y, y, ...]
        # Save [a0, a1, log2(lde_size) - 2, lde_size / 4] in memory next to the layer commitment
        dup.5
        add.4
        swap.6
        mem_storew_le
        swapw
        # => [num_layers, ptr_layer + 8, y, y, lde_size / 4, log2(lde_size) - 2, a0, a1, ...]

        # Decrement the FRI layer counter
        sub.1
        dup
        push.0
        neq
    end
    # => [Y, Y, ...]
    dropw
    dropw
    #=> [...]
end

#! Load and save the remainder polynomial from the advice provider and check that its hash
#! corresponds to its commitment and reseed with the latter.
#!
#! Input: [...]
#! Output: [...]
#!
#! Cycles:
#!
#!  1- Remainder polynomial of degree less
#!     than 64: 157
#!  2- Remainder polynomial of degree less
#!     than 128: 191
pub proc load_and_verify_remainder

    # `adv_pipe` the remainder codeword
    ## Get the numbers of FRI layers
    exec.constants::get_num_fri_layers
    ## Compute the correct remainder pointer, note that the remainder poly is laid out just after
    ## the FRI layer commitments, each saved in a word, and folding challenges, also saved in
    ## a word, and this explains the multiplication by 8
    mul.8 exec.constants::fri_com_ptr add
    #=> [fri_com_ptr, 8 * num_fri_layers, ...]
    ## Store for later use
    dup exec.constants::set_remainder_poly_address
    #=> [remainder_poly_ptr, ...]

    exec.constants::get_remainder_poly_size
    push.FRI_REMAINDER_POLY_MAX_DEGREE_PLUS_1_HALF

    eq
    if.true
        # Remainder polynomial degree less than 64
        # Load the random coin state as the initial sponge state.
        push.0 exec.constants::random_coin_output_len_ptr mem_store
        push.0 exec.constants::random_coin_input_len_ptr mem_store
        exec.random_coin::load_random_coin_state
        # => [R0, R1, C, remainder_poly_ptr, remainder_size, y, y]

        # adv_load remainder polynomial
        exec.load_fri_remainder_poly_max_degree_plus_1_half

        # Update the random coin state with the remainder polynomial digest.
        exec.random_coin::store_random_coin_state
        push.0 exec.constants::random_coin_input_len_ptr mem_store
        push.8 exec.constants::random_coin_output_len_ptr mem_store

    else
        # Remainder polynomial degree less than 128
        # Load the random coin state as the initial sponge state.
        push.0 exec.constants::random_coin_output_len_ptr mem_store
        push.0 exec.constants::random_coin_input_len_ptr mem_store
        exec.random_coin::load_random_coin_state
        # => [R0, R1, C, remainder_poly_ptr, remainder_size, y, y]

        # adv_load remainder polynomial
        exec.load_fri_remainder_poly_max_degree_plus_1
        # => [R0, R1, C, remainder_poly_ptr, remainder_size, y, y]

        # Update the random coin state with the remainder polynomial digest.
        exec.random_coin::store_random_coin_state
        push.0 exec.constants::random_coin_input_len_ptr mem_store
        push.8 exec.constants::random_coin_output_len_ptr mem_store

    end
    dropw dropw
    #=> [...]
end

#! Compute the pointer to the first word storing the FRI queries.
#!
#! Since the FRI queries are laid out just before the FRI commitments, we compute the address
#! to the first FRI query by subtracting from the pointer to the first FRI layer commitment
#! the total number of queries.
#!
#! Input: [...]
#! Output: [...]
#!
#! Cycles: 7
pub proc compute_query_pointer
    exec.constants::fri_com_ptr
    exec.constants::get_number_queries
    mul.4
    # => [num_queries*4, fri_com_ptr,  ...]

    sub
    # => [query_ptr, ...]

    exec.constants::set_fri_queries_address
    # => [...]
end
