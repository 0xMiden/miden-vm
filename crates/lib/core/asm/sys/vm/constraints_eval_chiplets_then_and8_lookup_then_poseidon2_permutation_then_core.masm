use miden::core::crypto::hashes::poseidon2
use miden::core::stark::constants
use miden::core::sys::vm::constraints_eval_inputs

# CONSTANTS
# =================================================================================================

# Number of READ variables (inputs + constants) for the constraint evaluation circuit.
const NUM_INPUTS_CIRCUIT = 696

# Number of evaluation gates in the constraint evaluation circuit.
const NUM_EVAL_GATES_CIRCUIT = 5568

# Max cycle length for periodic columns.
const MAX_CYCLE_LEN_LOG = 4

# ERRORS
# =================================================================================================

const ERR_FAILED_TO_LOAD_CIRCUIT_DESCRIPTION = "failed to load the circuit description for the constraints evaluation check"

# CONSTRAINT EVALUATION CHECKER
# =================================================================================================

#! Executes the constraints evaluation check for proof order: Chiplets then And8Lookup then Poseidon2Permutation then Core.
#!
#! Inputs:  []
#! Outputs: []
pub proc execute_constraint_evaluation_check()
    push.MAX_CYCLE_LEN_LOG
    exec.constraints_eval_inputs::set_up_auxiliary_inputs_ace

    exec.load_ace_circuit_description

    push.NUM_EVAL_GATES_CIRCUIT
    push.NUM_INPUTS_CIRCUIT
    exec.constants::public_inputs_address_ptr mem_load
    eval_circuit
    drop drop drop
end

#! Loads the description of this order-specific ACE circuit.
proc load_ace_circuit_description
    push.CIRCUIT_COMMITMENT
    adv.push_mapval
    exec.constants::ace_circuit_stream_ptr
    padw padw padw
    repeat.771
        adv_pipe
        exec.poseidon2::permute
    end
    exec.poseidon2::squeeze_digest
    movup.4 drop
    assert_eqw.err=ERR_FAILED_TO_LOAD_CIRCUIT_DESCRIPTION
end

