use miden::core::stark::constants

# Base-field offsets from `auxiliary_ace_inputs_ptr` to each AIR's selector triple.
# Kept in instance order for [Core, Chiplets, Poseidon2Permutation].
const MULTI_AIR_FOLD_BETA_OFFSET = 20
const CORE_SELECTOR_OFFSET = 22
const CHIPLETS_SELECTOR_OFFSET = 28
const POSEIDON2_PERMUTATION_SELECTOR_OFFSET = 34

#! Sets up the Miden VM ACE input layout.
#!
#! The stark-vars block starts with 10 EF slots:
#!
#!   Word 0 (slots 0-1): alpha, z^N
#!   Word 1 (slots 2-3): z_k, is_first
#!   Word 2 (slots 4-5): is_last, is_transition
#!   Word 3 (slots 6-7): reserved, weight0
#!   Word 4 (slots 8-9): f, s0
#!
#! The Miden multi-AIR layout then appends:
#!   slot 10: multi-air fold beta
#!   slots 11-13: lifted Core selectors
#!   slots 14-16: lifted Chiplets selectors
#!   slots 17-19: lifted Poseidon2Permutation selectors
#!
#! The multi-air fold beta is sampled by the generic random coin and stored in slot 10.
#!
#! Input:  [max_cycle_len_log, ...]
#! Output: [...]
pub proc set_up_auxiliary_inputs_ace
    padw exec.constants::composition_coef_ptr mem_loadw_le
    # => [alpha0, alpha1, beta0, beta1, max_cycle_len_log, ...]

    # multi-air fold beta.
    dup.3 dup.3
    # => [beta0, beta1, alpha0, alpha1, beta0, beta1, max_cycle_len_log, ...]
    push.0.0
    movup.3 movup.3
    # => [beta0, beta1, 0, 0, alpha0, alpha1, beta0, beta1, max_cycle_len_log, ...]
    exec.constants::auxiliary_ace_inputs_ptr add.MULTI_AIR_FOLD_BETA_OFFSET
    mem_storew_le dropw
    # => [alpha0, alpha1, beta0, beta1, max_cycle_len_log, ...]

    # alpha, z^N.
    movup.3 movup.3
    push.0.0 exec.constants::z_ptr mem_loadw_le
    # => [z_n_0, z_n_1, z_0, z_1, alpha0, alpha1, max_cycle_len_log, ...]

    # Compute z_k = z^(N / max_cycle_len) by repeated squaring.
    exec.constants::get_trace_length_log
    movup.7
    sub
    # => [k, z_n_0, z_n_1, z_0, z_1, alpha0, alpha1, ...]

    dup.4 dup.4
    # => [z_0, z_1, k, z_n_0, z_n_1, z_0, z_1, alpha0, alpha1, ...]

    push.1
    while.true
        dup.1 dup.1
        ext2mul
        dup.2 sub.1 swap.3
        push.1 neq
    end

    movup.2 drop
    # => [z_k_0, z_k_1, z_n_0, z_n_1, z_0, z_1, alpha0, alpha1, ...]

    movup.3 movup.3
    # => [z_n_0, z_n_1, z_k_0, z_k_1, z_0, z_1, alpha0, alpha1, ...]
    movup.7 movup.7
    # => [alpha0, alpha1, z_n_0, z_n_1, z_k_0, z_k_1, z_0, z_1, ...]

    exec.constants::auxiliary_ace_inputs_ptr
    mem_storew_le
    drop drop
    # => [z_n_0, z_n_1, z_k_0, z_k_1, z_0, z_1, ...]

    # is_first, is_last, is_transition.
    sub.1
    # => [van_0, van_1, z_k_0, z_k_1, z_0, z_1, ...]

    dup.5 dup.5
    # => [z_0, z_1, van_0, van_1, z_k_0, z_k_1, z_0, z_1, ...]
    sub.1 ext2inv
    # => [inv_z1_0, inv_z1_1, van_0, van_1, z_k_0, z_k_1, z_0, z_1, ...]
    dup.3 dup.3
    # => [van_0, van_1, inv_z1_0, inv_z1_1, van_0, van_1, z_k_0, z_k_1, z_0, z_1, ...]
    ext2mul
    # => [is_first_0, is_first_1, van_0, van_1, z_k_0, z_k_1, z_0, z_1, ...]

    movup.5 movup.5
    # => [z_k_0, z_k_1, is_first_0, is_first_1, van_0, van_1, z_0, z_1, ...]
    exec.constants::auxiliary_ace_inputs_ptr add.4
    mem_storew_le
    dropw
    # => [van_0, van_1, z_0, z_1, ...]

    exec.constants::get_trace_domain_generator
    inv
    # => [g_inv, van_0, van_1, z_0, z_1, ...]
    movup.3 swap sub
    # => [is_trans_0, van_0, van_1, z_1, ...]
    movup.3
    swap
    # => [is_trans_0, is_trans_1, van_0, van_1, ...]

    dup.1 dup.1
    # => [is_trans_0, is_trans_1, is_trans_0, is_trans_1, van_0, van_1, ...]
    ext2inv
    # => [inv_t_0, inv_t_1, is_trans_0, is_trans_1, van_0, van_1, ...]
    movup.5 movup.5
    # => [van_0, van_1, inv_t_0, inv_t_1, is_trans_0, is_trans_1, ...]
    ext2mul
    # => [is_last_0, is_last_1, is_trans_0, is_trans_1, ...]

    exec.constants::auxiliary_ace_inputs_ptr add.8
    mem_storew_le
    dropw
    # => [...]

    # f, s0, weight0, and the reserved slot.
    push.0
    exec.constants::get_domain_offset
    exec.constants::get_trace_length
    # => [trace_length, offset, 0, ...]
    exp.u32
    # => [s0, 0, ...]

    push.0
    exec.constants::get_lde_domain_generator
    exec.constants::get_trace_length
    exp.u32
    # => [f, 0, s0, 0, ...]

    dup.2 dup
    mul
    # => [s0^2, f, 0, s0, 0, ...]
    dup dup mul
    # => [s0^4, s0^2, f, 0, s0, 0, ...]
    mul
    # => [s0^6, f, 0, s0, 0, ...]
    dup.3 mul
    mul.8 inv
    # => [weight0, f, 0, s0, 0, ...]

    movdn.4
    # => [f, 0, s0, 0, weight0, ...]
    exec.constants::auxiliary_ace_inputs_ptr add.16
    mem_storew_le
    dropw
    # => [weight0, ...]

    push.0.0
    # => [0, 0, weight0, ...]
    push.0 movdn.3
    # => [0, 0, weight0, 0, ...]
    exec.constants::auxiliary_ace_inputs_ptr add.12
    mem_storew_le
    dropw

    # Per-AIR lifted selectors.
    exec.constants::get_core_trace_length_log
    push.CORE_SELECTOR_OFFSET
    exec.compute_per_air_selectors

    exec.constants::get_chiplets_trace_length_log
    push.CHIPLETS_SELECTOR_OFFSET
    exec.compute_per_air_selectors

    exec.constants::get_poseidon2_permutation_trace_length_log
    push.POSEIDON2_PERMUTATION_SELECTOR_OFFSET
    exec.compute_per_air_selectors
end

#! Load the quad field element stored at `[addr, addr + 1]`.
#!
#! Input:  [addr, ...]
#! Output: [q0, q1, ...]
proc load_quad
    dup add.1 mem_load
    swap mem_load
end

#! Compute one AIR's lifted selectors in the ACE input region.
#!
#! Input:  [out_offset, log_air, ...]
#! Output: [...]
proc compute_per_air_selectors
    swap
    exec.constants::get_trace_length_log
    swap sub
    # => [r_log, out_offset, ...]
    exec.constants::tmp4 mem_store
    # => [out_offset, ...]

    exec.constants::z_ptr add.2 exec.load_quad
    # => [z_0, z_1, out_offset, ...]
    exec.constants::tmp4 mem_load
    # => [r_log, z_0, z_1, out_offset, ...]
    dup push.0 neq
    while.true
        movdn.2
        dup.1 dup.1 ext2mul
        movup.2 sub.1
        dup push.0 neq
    end
    drop
    # => [z_lift_0, z_lift_1, out_offset, ...]

    exec.constants::auxiliary_ace_inputs_ptr add.2 exec.load_quad
    sub.1
    # => [van_0, van_1, z_lift_0, z_lift_1, out_offset, ...]

    dup.3 dup.3
    sub.1 ext2inv
    dup.3 dup.3 ext2mul
    # => [if_0, if_1, van_0, van_1, z_lift_0, z_lift_1, out_offset, ...]
    dup.6 exec.constants::auxiliary_ace_inputs_ptr add mem_store
    dup.5 exec.constants::auxiliary_ace_inputs_ptr add.1 add mem_store
    # => [van_0, van_1, z_lift_0, z_lift_1, out_offset, ...]

    exec.constants::get_trace_domain_generator
    inv
    exec.constants::tmp4 mem_load
    # => [r_log, g_max_inv, van_0, van_1, z_lift_0, z_lift_1, out_offset, ...]
    dup push.0 neq
    while.true
        swap dup mul
        swap sub.1
        dup push.0 neq
    end
    drop
    # => [g_air_inv, van_0, van_1, z_lift_0, z_lift_1, out_offset, ...]

    movup.3 swap sub
    movup.3
    swap
    # => [it_0, it_1, van_0, van_1, out_offset, ...]

    dup.1 dup.1
    ext2inv
    movup.5 movup.5
    ext2mul
    # => [il_0, il_1, it_0, it_1, out_offset, ...]

    dup.4 exec.constants::auxiliary_ace_inputs_ptr add.2 add mem_store
    dup.3 exec.constants::auxiliary_ace_inputs_ptr add.3 add mem_store
    # => [it_0, it_1, out_offset, ...]

    dup.2 exec.constants::auxiliary_ace_inputs_ptr add.4 add mem_store
    dup.1 exec.constants::auxiliary_ace_inputs_ptr add.5 add mem_store
    # => [out_offset, ...]
    drop
end
