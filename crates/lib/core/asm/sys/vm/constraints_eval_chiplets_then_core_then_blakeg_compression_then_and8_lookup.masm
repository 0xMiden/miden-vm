use miden::core::stark::constants
use miden::core::stark::utils

# CONSTANTS
# =================================================================================================

# Number of READ variables (inputs + constants) for the constraint evaluation circuit.
const NUM_INPUTS_CIRCUIT = 1184

# Number of evaluation gates in the constraint evaluation circuit.
const NUM_EVAL_GATES_CIRCUIT = 9760

# Max cycle length for periodic columns.
const MAX_CYCLE_LEN_LOG = 6

# Depth of the ACE circuit registry tree.
const ACE_REGISTRY_DEPTH = 5

# Initial chaining value for hashing the ACE circuit stream.
const CIRCUIT_STREAM_INIT_CV_0 = 4280581858871862887
const CIRCUIT_STREAM_INIT_CV_1 = 2688637133034287986
const CIRCUIT_STREAM_INIT_CV_2 = 1947077364412317696
const CIRCUIT_STREAM_INIT_CV_3 = 6620516959492516488

# ERRORS
# =================================================================================================

const ERR_CIRCUIT_COMMITMENT_MISMATCH = "hashed ACE circuit stream does not match registry commitment"

# CONSTRAINT EVALUATION CHECKER
# =================================================================================================

#! Executes the constraints evaluation check for proof order: Chiplets then Core then BlakeGCompression then And8Lookup.
#!
#! Inputs:  []
#! Outputs: []
pub proc execute_constraint_evaluation_check()
    push.MAX_CYCLE_LEN_LOG
    exec.utils::set_up_auxiliary_inputs_ace

    exec.load_and_authenticate_ace_circuit

    push.NUM_EVAL_GATES_CIRCUIT
    push.NUM_INPUTS_CIRCUIT
    exec.constants::public_inputs_address_ptr mem_load
    eval_circuit
    drop drop drop
end

#! Loads and authenticates this order-specific ACE circuit.
proc load_and_authenticate_ace_circuit
    exec.load_ace_registry_commitment
    # => [C]
    adv.push_mapval
    # => [C]
    exec.constants::ace_circuit_stream_ptr
    # => [ptr, C]
    push.CIRCUIT_STREAM_INIT_CV_3.CIRCUIT_STREAM_INIT_CV_2.CIRCUIT_STREAM_INIT_CV_1.CIRCUIT_STREAM_INIT_CV_0
    # => [CV, ptr, C]
    padw padw
    # => [BLOCK_SLOTS, CV, ptr, C]
    repeat.1361
        adv_pipe
        # => [BLOCK, CV, ptr_next, C]
        bcompress
        # => [BLOCK, CV_NEXT, ptr_next, C]
    end
    dropw dropw
    # => [DIGEST, ptr_final, C]
    movup.4 drop
    # => [DIGEST, C]
    assert_eqw.err=ERR_CIRCUIT_COMMITMENT_MISMATCH
    # => []
end

#! Loads the ACE circuit commitment selected by ORDER_TAG from the registry tree.
proc load_ace_registry_commitment
    exec.constants::relation_digest_ptr mem_loadw_le
    # => [REGISTRY_ROOT]
    exec.constants::get_order_tag
    # => [order_tag, REGISTRY_ROOT]
    push.ACE_REGISTRY_DEPTH
    # => [depth, order_tag, REGISTRY_ROOT]
    mtree_get
    # => [C, REGISTRY_ROOT]
    swapw dropw
    # => [C]
end

