use miden::core::sys::vm::constraints_eval_core_then_chiplets_then_poseidon2_permutation
use miden::core::sys::vm::constraints_eval_core_then_poseidon2_permutation_then_chiplets
use miden::core::sys::vm::constraints_eval_chiplets_then_core_then_poseidon2_permutation
use miden::core::sys::vm::constraints_eval_chiplets_then_poseidon2_permutation_then_core
use miden::core::sys::vm::constraints_eval_poseidon2_permutation_then_core_then_chiplets
use miden::core::sys::vm::constraints_eval_poseidon2_permutation_then_chiplets_then_core
use miden::core::stark::constants

# CONSTRAINT EVALUATION CHECK DISPATCHER
# =================================================================================================

#! Runs the order-specific recursive-verifier ACE circuit.
#!
#! `ORDER_TAG_PTR` is derived from the per-AIR trace heights during transcript
#! initialization and compared against each generated proof-order tag.
#!
#! Inputs:  []
#! Outputs: []
pub proc execute_constraint_evaluation_check
    exec.constants::assert_valid_order_tag
    exec.constants::get_order_tag
    push.0 eq
    if.true
        exec.constraints_eval_core_then_chiplets_then_poseidon2_permutation::execute_constraint_evaluation_check
    else
        exec.constants::get_order_tag
        push.1 eq
        if.true
            exec.constraints_eval_core_then_poseidon2_permutation_then_chiplets::execute_constraint_evaluation_check
        else
            exec.constants::get_order_tag
            push.2 eq
            if.true
                exec.constraints_eval_chiplets_then_core_then_poseidon2_permutation::execute_constraint_evaluation_check
            else
                exec.constants::get_order_tag
                push.3 eq
                if.true
                    exec.constraints_eval_chiplets_then_poseidon2_permutation_then_core::execute_constraint_evaluation_check
                else
                    exec.constants::get_order_tag
                    push.4 eq
                    if.true
                        exec.constraints_eval_poseidon2_permutation_then_core_then_chiplets::execute_constraint_evaluation_check
                    else
                        exec.constraints_eval_poseidon2_permutation_then_chiplets_then_core::execute_constraint_evaluation_check
                    end
                end
            end
        end
    end
end
