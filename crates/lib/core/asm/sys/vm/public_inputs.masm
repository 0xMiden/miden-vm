use miden::core::stark::constants
use miden::core::stark::public_inputs
use miden::core::stark::random_coin
use miden::core::crypto::hashes::poseidon2
use miden::core::sys::vm::claim

# PUBLIC INPUTS PROCESSING FOR MIDEN VM RECURSIVE VERIFIER
# =================================================================================================
#
# This module handles the Miden VM-specific public input processing for the recursive verifier.
# It (a) computes `kernel_H`, the Poseidon2 hash (`hash_elements`) of all kernel-procedure
# digests, (b) materializes the kernel digests and populates the caller-facing boundary-inputs
# block and the FLPI section of the ACE READ region, and (c) absorbs every public input into the
# Fiat-Shamir transcript in a rate-aligned schedule mirroring `MidenMultiAir::observe` on the Rust
# side. The outer-LogUp boundary correction `c_total` is computed later, in step II
# (`observe_aux_trace`), once the aux randomness has been sampled from the transcript.
#
# Memory layout populated (low -> high addresses):
#
#   boundary_inputs_ptr --> [ kernel_H          (4 felts) ]   caller-facing boundary-inputs
#                           [ program_digest    (4 felts) ]   block (16 felts). The trailing
#                           [ deferred_root     (4 felts) ]   pad keeps the FS observation
#                           [ zero pad          (4 felts) ]   rate-aligned (two 8-felt chunks).
#
#   pi_ptr             -->  [ FLPI: 32 base felts as 32 EF slots ]   stack i/o
#
#   anchor             -->  [ aux_rand: beta0,beta1,alpha0,alpha1 ]   AUX_RAND_ELEM_PTR (sampled
#                                                                     from the transcript in step II)
#
# The trailing pad slot is written to zero before the boundary-inputs window is absorbed, so the FS
# observation does not depend on the scratch region being zero-initialized.
#
# The outer-LogUp boundary correction accumulated at `C_TOTAL_PTR` is the signed sum of one
# inverted bus term per boundary interaction:
#
#     c_total = Σ_i 1 / d(KernelRomInit,           kernel_digest_i)   (request,  +1)
#             +     1 / d(BlockHashTable,           program_digest)   (request,  +1)
#             +     1 / d(LogDeferredRoot,           <empty>)          (request,  +1)
#             −     1 / d(LogDeferredRoot,           deferred_root)     (response, −1)
#
# where the bus-message denominator is `d(bus, w) = (α + (bus + 1)·γ) + msg(w)`, the prefix
# scale `bus + 1` is the matching `BUS_ID_*_PLUS_ONE` constant, `γ = β^MAX_MESSAGE_WIDTH`, and
# `msg(w) = Σ_{j<4} w_j·β^j` (the empty message of the init term gives `msg = 0`). It is
# computed in step II (`observe_aux_trace`) from the FS-sampled `α, β`, over the kernel digests,
# program digest and deferred root materialized in step I; `observe_aux_trace` then asserts
# the boundary identity `c_total + aux_sum == 0` against the absorbed per-AIR LogUp finals.
# Requests (multiplicity +1) are added and the single response (−1) is subtracted, so `c_total`
# is accumulated as `requests − response`.
#
# Fiat-Shamir absorption order (`MidenMultiAir::observe`): one statement block
#   1. CLAIM_HASH + deferred_root                     (4 + 4 = 8 felts)
# where CLAIM_HASH is the canonical execution-claim commitment over
# `program_digest ‖ kernel_H ‖ stack_inputs ‖ stack_outputs` (computed inline by
# `compute_claim_commitment`). With RELATION_DIGEST pre-loaded in the transcript capacity by
# `init_seed`, the state after this block realizes `H(RELATION_DIGEST ‖ CLAIM_HASH ‖ D)`.
# The raw stack i/o and kernel digests remain public values for the constraint checks and the
# LogUp boundary without being separately absorbed.
#
# Data sources:
#   - claim region: caller memory at `claim_ptr` (operand), 40 base felts `P | K | I | O`;
#     the caller fills P, I, O and `stage_boundary_inputs` writes K.
#   - kernel digests: caller memory at `kernel_ptr` (operand), N word-aligned digests; hashed
#     into K and re-read for the step-II boundary fold.
#   - deferred_root: advice (4 canonical felts), loaded by `stage_boundary_inputs`.
#
# `stage_boundary_inputs` completes the claim region and stages kernel_H, program_digest and
# deferred_root into the boundary-inputs block before the transcript starts;
# `process_public_inputs` then only absorbs into FS.
#
# CONSTANTS
# =================================================================================================

# Number of fixed length public inputs (in field elements): stack inputs (16) + stack
# outputs (16). These are the only public values referenced by the ACE circuit; the program
# digest and deferred root live in the caller-facing boundary-inputs block instead.
# Domain tag for the claim commitment: the registered selector
# (EXECUTION_CLAIM_DOMAIN_ID << 8) | version = (33 << 8) | 1, per the Miden
# domain-separation RFC (https://github.com/0xMiden/crypto/pull/1026). Must match
# miden_core::program::CLAIM_DOMAIN_TAG and the const in claim.masm (enforced by the
# e2e recursion tests).
const CLAIM_DOMAIN_TAG = 8449

const NUM_FIXED_LEN_PUBLIC_INPUTS = 32

# Number of AIR instances in the Miden VM statement.
const NUM_MIDEN_AIRS = 3

# Bus prefix scale factors: `prefix_id = α + (BusId + 1)·γ` with `γ = β^16`.
const BUS_ID_KERNEL_ROM_INIT_PLUS_ONE           = 1   # KernelRomInit (0) + 1
const BUS_ID_BLOCK_HASH_TABLE_PLUS_ONE          = 2   # BlockHashTable (1) + 1
const BUS_ID_LOG_DEFERRED_ROOT_PLUS_ONE         = 3   # LogDeferredRoot (2) + 1

# Word offsets into the 16-felt boundary-inputs block at `boundary_inputs_ptr`:
#   [ kernel_H (+0) | program_digest (+4) | deferred_root (+8) | zero pad (+12) ].
const BOUNDARY_INPUTS_PROGRAM_OFFSET    = 4
const BOUNDARY_INPUTS_DEFERRED_OFFSET   = 8


# CONSTANTS GETTERS
# =================================================================================================

pub proc get_num_fixed_len_public_inputs
    push.NUM_FIXED_LEN_PUBLIC_INPUTS
end

# MAIN PROCEDURE
# =================================================================================================

#! Processes the public inputs (step I of the verifier).
#!
#! See module banner for the memory layout, the canonical FS schedule and the advice tape
#! order.
#!
#! Precondition:  random coin input_len=0 (guaranteed by `init_seed`, which absorbs the
#!                protocol parameters as one full rate block).
#! Postcondition: the transcript input buffer holds the AIR-shape values. The generic verifier
#!                observes the main-trace commitment next and flushes before sampling.
#!
#! Input:  [...]
#! Output: [...]
pub proc process_public_inputs
    # Assert precondition: the rate-aligned absorption below bypasses the buffered duplex.
    exec.constants::random_coin_input_len_ptr mem_load
    assertz.err="process_public_inputs: input buffer must be empty"

    # 1) Compute and store `pi_ptr`; publish the fixed boundary-inputs block address separately.
    exec.get_num_fixed_len_public_inputs
    exec.public_inputs::compute_and_store_public_inputs_address
    exec.store_boundary_inputs_address
    # => [...]

    # 2) Compute CLAIM_HASH over the caller's claim region (completed by
    #    `stage_boundary_inputs`) and absorb the statement block [CLAIM_HASH | D] into FS.
    exec.constants::claim_address_ptr mem_load
    exec.claim::claim_commitment
    # => [CLAIM_HASH, ...]
    exec.absorb_claim_and_deferred_into_fs
    # => [...]

    # 3) Load FLPI (stack i/o) from caller memory into the FLPI region (public values for the
    #    constraint checks; not separately absorbed — the transcript sees them via CLAIM_HASH).
    exec.load_public_inputs
    # => [...]

    # 4) Observe the AIR count and per-AIR log heights.
    exec.observe_miden_air_shape
    # => [...]
end

#! Publishes the fixed boundary-inputs block address for caller-facing output readers.
#!
#! Input:  [...]
#! Output: [...]
proc store_boundary_inputs_address
    exec.constants::boundary_inputs_ptr
    exec.constants::boundary_inputs_address_ptr mem_store
end

#! Stages the boundary-inputs block at the fixed standalone `BOUNDARY_INPUTS_PTR` before the
#! transcript starts (called by `verify_vm_proof`).
#!
#! Writes, in order:
#!   claim_ptr+4       : K = kernel_commitment(kernel_ptr, N), completing the caller's claim
#!                       region (the caller filled P, I, O).
#!   boundary_inputs+0  : K, for the step-II boundary fold and caller-facing readers.
#!   boundary_inputs+4  : program_digest, copied from the claim region.
#!   boundary_inputs+8  : deferred_root, loaded from advice.
#!
#! Also persists `claim_ptr`, `kernel_ptr`, and the digest count `N` into their fixed cells so
#! the step-I FLPI load and the step-II boundary fold can re-read the same caller-owned regions.
#! The trailing pad word of the window is never written and reads as zero.
#!
#! Input:  [claim_ptr, kernel_ptr, N, ...]
#! Output: [...]
pub proc stage_boundary_inputs
    # Persist N (bounded by KernelDescriptor::MAX_NUM_PROCEDURES) and the caller pointers.
    dup.2
    u32assert.err="number of kernel procedure digests must fit in a u32"
    dup u32lt.256 assert.err="number of kernel procedure digests exceeds KernelDescriptor::MAX_NUM_PROCEDURES"
    exec.constants::num_kernel_digests_ptr mem_store
    # => [claim_ptr, kernel_ptr, N, ...]
    dup.1 exec.constants::kernel_digests_address_ptr mem_store
    dup exec.constants::claim_address_ptr mem_store
    # => [claim_ptr, kernel_ptr, N, ...]

    # K = kernel_commitment(kernel_ptr, N) -> claim region (+4) and the window (+0).
    movup.2 movup.2
    # => [kernel_ptr, N, claim_ptr, ...]
    exec.claim::kernel_commitment
    # => [K, claim_ptr, ...]
    dup.4 add.4 mem_storew_le
    exec.constants::boundary_inputs_ptr mem_storew_le
    # => [K, claim_ptr, ...]

    # program_digest: claim region (+0) -> boundary_inputs + BOUNDARY_INPUTS_PROGRAM_OFFSET.
    # The dead K word is the load target (mem_loadw_le overwrites the top word).
    movup.4 mem_loadw_le
    # => [P, ...]
    exec.constants::boundary_inputs_ptr add.BOUNDARY_INPUTS_PROGRAM_OFFSET mem_storew_le
    # => [P, ...]

    # deferred_root from advice -> boundary_inputs + BOUNDARY_INPUTS_DEFERRED_OFFSET, loaded
    # over the dead P word.
    adv_loadw
    exec.constants::boundary_inputs_ptr add.BOUNDARY_INPUTS_DEFERRED_OFFSET mem_storew_le dropw
    # => [...]
end

#! Loads the final deferred root from the boundary-inputs window.
#!
#! Input:  [...]
#! Output: [D, ...]
pub proc load_deferred_root
    padw exec.constants::boundary_inputs_ptr add.BOUNDARY_INPUTS_DEFERRED_OFFSET mem_loadw_le
end

# HELPER PROCEDURES
# =================================================================================================

#! Computes `γ = β^MAX_MESSAGE_WIDTH` for per-bus domain separation and stores it at
#! BUS_GAMMA_PTR as `[γ0, γ1, 0, 0]`.
#!
#! The four squarings below reach `β^16`; `MAX_MESSAGE_WIDTH` is hardcoded as 16 here, guarded
#! by the `MIDEN_MAX_MESSAGE_WIDTH` tripwire in `air/src/constraints/lookup/messages.rs`.
#!
#! Input:  [...]
#! Output: [...]
proc compute_bus_gamma
    exec.push_beta
    # => [β0, β1, ...]
    dup.1 dup.1 ext2mul   # β^2
    dup.1 dup.1 ext2mul   # β^4
    dup.1 dup.1 ext2mul   # β^8
    dup.1 dup.1 ext2mul   # β^16 = γ
    push.0.0 movup.3 movup.3
    exec.constants::bus_gamma_ptr mem_storew_le
    dropw
end

#! Pushes the auxiliary randomness β onto the stack.
#!
#! Input:  [...]
#! Output: [β0, β1, ...]
proc push_beta
    exec.constants::aux_rand_elem_ptr add.1 mem_load
    exec.constants::aux_rand_elem_ptr mem_load
end

#! Computes the bus prefix `α + i·γ` for bus scale factor `i = bus_id + 1`.
#!
#! Input:  [i, ...]
#! Output: [p0, p1, ...]
proc push_alpha_plus_i_gamma
    dup
    exec.constants::bus_gamma_ptr add.1 mem_load mul
    # => [i·γ1, i, ...]
    swap
    exec.constants::bus_gamma_ptr mem_load mul
    # => [i·γ0, i·γ1, ...]
    exec.constants::aux_rand_elem_ptr add.3 mem_load
    exec.constants::aux_rand_elem_ptr add.2 mem_load
    # => [α0, α1, i·γ0, i·γ1, ...]
    ext2add
    # => [p0, p1, ...]
end

#! Folds a 4-felt message word into `msg = m0 + m1·β + m2·β^2 + m3·β^3` via Horner
#! evaluation, consuming the word from the stack.
#!
#! Input:  [m0, m1, m2, m3, ...]
#! Output: [msg0, msg1, ...]
proc fold_digest_word
    movup.3 push.0 swap
    # => [m3, 0, m0, m1, m2, ...]
    exec.push_beta ext2mul
    movup.4 add
    # => [acc0, acc1, m0, m1, ...]
    exec.push_beta ext2mul
    movup.3 add
    # => [acc0, acc1, m0, ...]
    exec.push_beta ext2mul
    movup.2 add
    # => [msg0, msg1, ...]
end

#! Folds each kernel digest into the running boundary-correction accumulator on the stack.
#!
#! Each digest in `[base, base + 4·N)` contributes `1 / ((α + γ) + msg(d))` (KernelRomInit, a
#! request) via Horner evaluation. The accumulator is kept on the stack across the loop (no
#! per-term memory round-trip).
#!
#! Input:  [acc0, acc1, base, N, ...]
#! Output: [acc0, acc1, ...]   (acc += Σ_i 1 / ((α + γ) + msg(digest_i)))
proc fold_kernel_digests_into_acc
    dup.3 push.0 neq
    while.true
        # Loop entry: [acc0, acc1, base, N, ...]
        padw dup.6 mem_loadw_le
        # => [d0, d1, d2, d3, acc0, acc1, base, N, ...]
        exec.fold_digest_word
        # => [msg0, msg1, acc0, acc1, base, N, ...]
        push.BUS_ID_KERNEL_ROM_INIT_PLUS_ONE
        exec.push_alpha_plus_i_gamma
        # => [p0, p1, msg0, msg1, acc0, acc1, base, N, ...]
        ext2add ext2inv
        # => [t0, t1, acc0, acc1, base, N, ...]
        ext2add
        # => [acc0, acc1, base, N, ...]   (acc += t)
        movup.2 add.4 movdn.2
        # => [acc0, acc1, base+4, N, ...]
        movup.3 sub.1 movdn.3
        # => [acc0, acc1, base+4, N-1, ...]
        dup.3 push.0 neq
        # => [N-1 != 0, acc0, acc1, base+4, N-1, ...]
    end
    movup.3 drop movup.2 drop
    # => [acc0, acc1, ...]
end

#! Reads the canonical word `[d0, d1, d2, d3]` at `boundary_inputs_ptr + offset` (written in step I)
#! and computes the inverted bus term
#!     inv_term = 1 / ((α + i·γ) + msg(d))
#! where `i = bus_id_plus_one` and `msg(d) = Σ_{j<4} d_j·β^j`. The caller adds (request) or
#! subtracts (response) the result from the boundary accumulator.
#!
#! Input:  [bus_id_plus_one, offset, ...]
#! Output: [inv_term0, inv_term1, ...]
proc fold_boundary_word_inv_term
    padw
    # => [0, 0, 0, 0, bus_id, offset, ...]
    exec.constants::boundary_inputs_address_ptr mem_load
    dup.6 add
    # => [target, 0, 0, 0, 0, bus_id, offset, ...]
    mem_loadw_le
    # => [d0, d1, d2, d3, bus_id, offset, ...]

    exec.fold_digest_word
    # => [msg0, msg1, bus_id, offset, ...]

    movup.2
    # => [bus_id, msg0, msg1, offset, ...]
    exec.push_alpha_plus_i_gamma
    # => [p0, p1, msg0, msg1, offset, ...]
    ext2add ext2inv
    # => [inv_term0, inv_term1, offset, ...]

    movup.2 drop
    # => [inv_term0, inv_term1, ...]
end

#! Computes the outer-LogUp boundary correction `c_total` and stores it at `C_TOTAL_PTR`
#! (step II). Requires the aux randomness to have been sampled into `AUX_RAND_ELEM_PTR` by
#! `generate_aux_randomness` first.
#!
#! Derives `γ = β^16`, then folds the request/response terms over the caller-owned kernel digests
#! at `KERNEL_DIGESTS_ADDRESS_PTR` (count at `NUM_KERNEL_DIGESTS_PTR`) and the program digest /
#! deferred root in the boundary-inputs block, all staged in `stage_boundary_inputs`. Mirrors the module
#! banner's `c_total` definition and `MidenMultiAir::eval_external`.
#!
#! Input:  [...]
#! Output: [...]
pub proc compute_outer_logup_correction
    # γ = β^16 into BUS_GAMMA_PTR.
    exec.compute_bus_gamma
    # => [...]

    # acc = 0; build [acc0, acc1, base, N] for the kernel fold.
    push.0.0
    exec.constants::kernel_digests_address_ptr mem_load movdn.2
    exec.constants::num_kernel_digests_ptr mem_load movdn.3
    # => [acc0, acc1, base, N, ...]   (acc = 0)

    #    Request a) kernel digests: Σ_i 1 / ((α + γ) + msg(digest_i)).
    exec.fold_kernel_digests_into_acc
    # => [acc0, acc1, ...]

    #    Request b) program digest: + 1 / ((α + 2γ) + msg(program)) from boundary_inputs+4.
    push.BOUNDARY_INPUTS_PROGRAM_OFFSET push.BUS_ID_BLOCK_HASH_TABLE_PLUS_ONE
    exec.fold_boundary_word_inv_term
    ext2add
    # => [acc0, acc1, ...]

    #    Request c) log-deferred init: + 1 / (α + 3γ) (the init message is all zeros).
    push.BUS_ID_LOG_DEFERRED_ROOT_PLUS_ONE
    exec.push_alpha_plus_i_gamma
    ext2inv
    ext2add
    # => [acc0, acc1, ...]

    #    Response) deferred root: − 1 / ((α + 3γ) + msg(deferred_root)) from boundary_inputs+8.
    push.BOUNDARY_INPUTS_DEFERRED_OFFSET push.BUS_ID_LOG_DEFERRED_ROOT_PLUS_ONE
    exec.fold_boundary_word_inv_term
    neg swap neg swap
    ext2add
    # => [acc0, acc1, ...]   (acc = requests − response)

    #    Store c_total once.
    exec.constants::c_total_ptr mem_store
    exec.constants::c_total_ptr add.1 mem_store
    # => [...]
end

#! Observes the 16-felt boundary-inputs window at `boundary_inputs_ptr + 0..+15` into the FS
#! transcript as two rate-aligned 8-felt chunks via `mem_stream + permute`:
#!   Chunk 1: `[kernel_H | program_digest]`   at boundary_inputs+0..+7.
#!   Chunk 2: `[deferred_root | zero_pad]` at boundary_inputs+8..+15.
#! The trailing pad word is written to zero here so the absorption does not depend on the scratch
#! region being zero-initialized.
#!
#! POSTCONDITION: random coin input_len=0, output_len=8 on return.
#!
#! Input:  [...]
#! Output: [...]
#! Absorbs the single statement block `[CLAIM_HASH | D]` into the FS transcript, mirroring
#! `MidenMultiAir::observe`. With RELATION_DIGEST pre-loaded in the transcript capacity
#! (`init_seed`), the resulting state realizes the factored statement binding
#! `H(RELATION_DIGEST ‖ CLAIM_HASH ‖ D)`.
#!
#! Input:  [CLAIM_HASH, ...]
#! Output: [...]
proc absorb_claim_and_deferred_into_fs
    # D from the boundary-inputs window
    padw exec.constants::boundary_inputs_address_ptr mem_load add.BOUNDARY_INPUTS_DEFERRED_OFFSET mem_loadw_le
    # => [D, CLAIM_HASH, ...]

    push.0 exec.constants::random_coin_output_len_ptr mem_store
    # Duplex overwrite mode: the stale rate words are never read, so load only the capacity
    # and build the rate from [CLAIM_HASH | D] already on the stack.
    exec.random_coin::get_capacity
    # => [C, D, CLAIM_HASH, ...]
    swapw.2
    # => [CLAIM_HASH, D, C, ...]

    # Bind the absorbed length (8) into the capacity before the absorb permutation.
    movup.8 add.8 movdn.8
    exec.poseidon2::permute
    # => [R1', R2', C', ...]

    exec.random_coin::store_random_coin_state
    push.8 exec.constants::random_coin_output_len_ptr mem_store
    # => [...]
end

#! Loads stack i/o from caller memory at `STACK_IO_ADDRESS_PTR` and stores it at `pi_ptr` as
#! extension field elements (each base felt at offset `2*i`, zero in the high coordinate).
#!
#! The values are public inputs for the constraint checks only; they are NOT absorbed into the
#! FS transcript (the transcript binds them via CLAIM_HASH).
#!
#! Input:  [...]
#! Output: [...]
proc load_public_inputs
    padw padw padw
    # => [SCRATCH(12), ...]
    exec.constants::claim_address_ptr mem_load add.8
    movdn.12
    exec.constants::public_inputs_address_ptr mem_load
    movdn.12
    # => [SCRATCH(12), pi_ptr, claim_io_ptr, ...]

    # 4 iterations x 8 = 32 = NUM_FIXED_LEN_PUBLIC_INPUTS.
    repeat.4
        exec.public_inputs::load_base_store_extension_double_word_from_mem
    end
    # => [SCRATCH'(12), pi_ptr + 64, claim_io_ptr + 32, ...]

    dropw dropw dropw drop drop
    # => [...]
end

#! Observe the Miden AIR shape into the Fiat-Shamir transcript.
#!
#! This matches the framework's shape observation: instance count followed by per-AIR log heights in
#! instance order.
#!
#! Input:  [...]
#! Output: [...]
proc observe_miden_air_shape
    exec.constants::get_poseidon2_permutation_trace_length_log
    exec.constants::get_chiplets_trace_length_log
    exec.constants::get_core_trace_length_log
    push.NUM_MIDEN_AIRS
    # => [NUM_MIDEN_AIRS, core_log, chiplets_log, poseidon2_log, ...]
    exec.random_coin::observe_word
end
