pub proc get_sig_segment_len
    push.SEGMENT_LEN
end

pub proc get_sig_message_size
    push.MESSAGE_SIZE
end

pub proc get_sig_code_gen
    push.CODE_GEN
end

pub proc get_sig_trace_gen
    push.TRACE_GEN
end

pub proc get_sig_omega_7
    push.OMEGA_7
end

pub proc get_sig_coset_offset
    push.COSET_OFFSET
end

pub proc get_sig_coset_offset_inv
    push.COSET_OFFSET_INV
end
