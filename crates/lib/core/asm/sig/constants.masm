# ─────────────────────────────────────────────────────────────────────────────
#   Shared random-coin sponge pointers — re-exported from stark::constants.
#
#   sig/mod.masm reuses the STARK random-coin sponge memory region (it calls
#   random_coin::{store_random_coin_state, get_capacity, get_rate_2}, which read
#   and write via stark's r1_ptr/r2_ptr/c_ptr). Rather than hardcode those
#   addresses as literals — which would silently corrupt the transcript if next's
#   random-coin layout ever moves — mod.masm reads them through these wrappers so
#   stark::constants stays the single source of truth.
# ─────────────────────────────────────────────────────────────────────────────

pub proc rc_r1_ptr
    exec.constants::r1_ptr
end

pub proc rc_input_len_ptr
    exec.constants::random_coin_input_len_ptr
end

pub proc rc_output_len_ptr
    exec.constants::random_coin_output_len_ptr
end
