pub proc sig_deep_poly_ptr
    push.SIG_DEEP_POLY_PTR
end

pub proc sig_queries_ptr
    push.SIG_QUERIES_PTR
end

pub proc sig_queries_end_ptr
    push.SIG_QUERIES_END_PTR
end

pub proc sig_opened_row_ptr
    push.SIG_OPENED_ROW_PTR
end

