pub proc get_sig_witness_width
    push.WITNESS_WIDTH
end

pub proc get_sig_aux_width
    push.AUX_WIDTH
end

pub proc get_sig_num_quotient_chunks
    push.NUM_QUOTIENT_CHUNKS
