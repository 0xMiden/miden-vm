    push.SIG_LAMBDA_PTR
end

pub proc sig_deep_coefs_ptr
    push.SIG_DEEP_COEFS_PTR
end

pub proc sig_alpha_inv_ptr
    push.SIG_ALPHA_INV_PTR
end

pub proc sig_horner_fixed_ptr
    push.SIG_HORNER_FIXED_PTR
end

pub proc sig_neg_z_gz_ptr
    push.SIG_NEG_Z_GZ_PTR
end

pub proc sig_ood_ptr
    push.SIG_OOD_PTR
